def _load_offsets() -> dict[str, int]:
    if not TRANSCRIPT_OFFSETS.exists():
        return {}
    try:
        return json.loads(TRANSCRIPT_OFFSETS.read_text())
    except (json.JSONDecodeError, OSError):
        return {}


def _save_offsets(data: dict[str, int]) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    TRANSCRIPT_OFFSETS.write_text(json.dumps(data))


def _post(url: str, payload: dict) -> None:
    data = json.dumps(payload, ensure_ascii=False, default=str).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=3)
    except (urllib.error.URLError, TimeoutError, OSError) as exc:
        print(f"cot: failed to post event: {exc}", file=sys.stderr)


def _post_async(url: str, payload: dict) -> None:
    """Fire-and-forget — only for non-critical follow-up posts."""
    def _send() -> None:
        _post(url, payload)

    threading.Thread(target=_send, daemon=True).start()


def _audit_self(action: str, *, target: str | None = None, status: str = "ok", detail: dict | None = None) -> None:
    """Best-effort self-audit for bridge config changes."""
    payload = {
        "action": action,
        "actor": "cot-bridge",
        "target": target,
        "status": status,
        "detail": detail or {},
    }
    data = json.dumps(payload, ensure_ascii=False, default=str).encode("utf-8")
    req = urllib.request.Request(
        f"{COT_ENDPOINT}/v1/audit/self",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        urllib.request.urlopen(req, timeout=2)
    except (urllib.error.URLError, TimeoutError, OSError):
        pass


def _now_z() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def _ordered_ts(base: object, index: int) -> str:
    """A timestamp derived from *base* plus *index* ms, so a batch of events
    emitted together keeps a stable, increasing order in the timeline."""
    if not base:
        base = _now_z()
    try:
        dt = datetime.fromisoformat(str(base).replace("Z", "+00:00")) + timedelta(milliseconds=index)
        return dt.isoformat(timespec="milliseconds").replace("+00:00", "Z")
    except ValueError:
        return str(base)


def _img_dims(raw: bytes) -> tuple[int | None, int | None]:
    """Best-effort pixel dimensions from raw image bytes (PNG/GIF/JPEG)."""
    try:
        if raw[:8] == b"\x89PNG\r\n\x1a\n":
            w, h = struct.unpack(">II", raw[16:24])
            return w, h
        if raw[:6] in (b"GIF87a", b"GIF89a"):
            w, h = struct.unpack("<HH", raw[6:10])
            return w, h
        if raw[:2] == b"\xff\xd8":  # JPEG: scan for a start-of-frame marker
            i, n = 2, len(raw)
            while i + 9 < n:
                if raw[i] != 0xFF:
                    i += 1
                    continue
                marker = raw[i + 1]
                if 0xC0 <= marker <= 0xCF and marker not in (0xC4, 0xC8, 0xCC):
                    h, w = struct.unpack(">HH", raw[i + 5 : i + 9])
                    return w, h
                seg = struct.unpack(">H", raw[i + 2 : i + 4])[0]
                i += 2 + seg
    except Exception:
        pass
    return None, None


def _kind_for_media_type(media_type: str | None) -> str:
    return "image" if media_type and media_type.startswith("image/") else "document"


def _meta_from_bytes(meta: dict, raw: bytes) -> None:
    meta["size_bytes"] = len(raw)
    if meta.get("kind") == "image":
        w, h = _img_dims(raw)
        if w:
            meta["width"], meta["height"] = w, h


def _decode_data_url(value: str) -> tuple[str | None, bytes | None]:
    if not value.startswith("data:") or "," not in value:
        return None, None
    header, data = value.split(",", 1)
    media_type = header[5:].split(";", 1)[0] or None
    if ";base64" not in header:
        return media_type, None
    try:
        return media_type, base64.b64decode(data)
    except Exception:
        return media_type, None


def _uploaded_documents_from_text(text: str) -> list[dict]:
    """Cursor records chat uploads as an uploaded_documents text preamble."""
    match = re.search(r"<uploaded_documents>(.*?)</uploaded_documents>", text, re.S)
    if not match:
        return []
    out: list[dict] = []
    for raw_line in match.group(1).splitlines():
        line = raw_line.strip()
        if not line.startswith("- "):
            continue
        m = re.match(r"-\s+(.+?)(?:\s+\(([^)]+)\))?$", line)
        if not m:
            continue
        path_text = m.group(1).strip()
        name = (m.group(2) or Path(path_text).name).strip()
        media_type = mimetypes.guess_type(name)[0] or mimetypes.guess_type(path_text)[0]
        meta: dict = {"kind": _kind_for_media_type(media_type), "media_type": media_type}
        if name:
            meta["name"] = name
            ext = Path(name).suffix.lstrip(".").lower()
            if ext:
                meta["extension"] = ext
        try:
            p = Path(path_text).expanduser()
            if p.is_file():
                meta["size_bytes"] = p.stat().st_size
        except OSError:
            pass
        out.append(meta)
    return out


def _codex_files_from_text(text: str) -> list[dict]:
    """Codex records some uploads only as a leading Files-mentioned preamble."""
    stripped = text.lstrip()
    if not stripped.startswith("# Files mentioned by the user:"):
        return []
    header = stripped.split("## My request for Codex:", 1)[0]
    out: list[dict] = []
    for raw_line in header.splitlines():
        line = raw_line.strip()
        if not line.startswith("## "):
            continue
        entry = line[3:].strip()
        if ": " not in entry:
            continue
        name, path_text = entry.rsplit(": ", 1)
        name = name.strip()
        path_text = path_text.strip()
        media_type = mimetypes.guess_type(name)[0] or mimetypes.guess_type(path_text)[0]
        meta: dict = {"kind": _kind_for_media_type(media_type), "media_type": media_type}
        if name:
            meta["name"] = name
            ext = Path(name).suffix.lstrip(".").lower()
            if ext:
                meta["extension"] = ext
        try:
            p = Path(path_text).expanduser()
            if p.is_file():
                meta["size_bytes"] = p.stat().st_size
        except OSError:
            pass
        out.append(meta)
    return out


def _file_attachment_meta(attachment: dict) -> dict | None:
    if attachment.get("type") != "file":
        return None
    filename = attachment.get("filename")
    content = attachment.get("content") if isinstance(attachment.get("content"), dict) else {}
    file_info = content.get("file") if isinstance(content.get("file"), dict) else {}
    path_text = str(file_info.get("filePath") or filename or "")
    name = Path(path_text).name if path_text else ""
    media_type = mimetypes.guess_type(name)[0] or mimetypes.guess_type(path_text)[0]
    meta: dict = {"kind": _kind_for_media_type(media_type), "media_type": media_type}
    if name:
        meta["name"] = name
        ext = Path(name).suffix.lstrip(".").lower()
        if ext:
            meta["extension"] = ext
    if isinstance(file_info.get("content"), str):
        meta["size_bytes"] = len(file_info["content"].encode("utf-8"))
    elif path_text:
        try:
            p = Path(path_text).expanduser()
            if p.is_file():
                meta["size_bytes"] = p.stat().st_size
        except OSError:
            pass
    return meta


def _file_attachment_matches_text(attachment: dict, text: str | None) -> bool:
    if not text:
        return False
    if "@" not in text:
        return False
    filename = str(attachment.get("filename") or "")
    if filename and re.search(rf"@['\"]?{re.escape(filename)}(?:['\"]|\s|$)", text):
        return True
    name = Path(filename).name if filename else ""
    return bool(name and re.search(rf"@['\"]?[^'\"]*{re.escape(name)}(?:['\"]|\s|$)", text))


def _message_attachments(content: list) -> list[dict]:
    """Metadata for non-text user attachments (images / documents): kind,
    media_type, byte size, and pixel dimensions — never the raw bytes."""
    out: list[dict] = []
    has_structured_upload = any(
        isinstance(block, dict) and block.get("type") in ("image", "document", "input_image", "input_file")
        for block in content
    )
    for block in content:
        if not isinstance(block, dict):
            continue
        bt = block.get("type")
        if bt in ("text", "input_text"):
            text = block.get("text")
            if isinstance(text, str):
                out.extend(_uploaded_documents_from_text(text))
                if not has_structured_upload:
                    out.extend(_codex_files_from_text(text))
            continue
        if bt not in ("image", "document", "input_image", "input_file"):
            continue
        src = block.get("source") if isinstance(block.get("source"), dict) else {}
        media_type = src.get("media_type") or block.get("media_type") or block.get("mime_type")
        raw: bytes | None = None
        if bt == "input_image":
            media_type, raw = _decode_data_url(str(block.get("image_url") or ""))
        elif bt == "input_file":
            media_type, raw = _decode_data_url(str(block.get("file_data") or ""))
        kind = "image" if bt in ("image", "input_image") else "document"
        if media_type and bt == "input_file":
            kind = _kind_for_media_type(media_type)
        meta: dict = {"kind": kind, "media_type": media_type}
        name = block.get("title") or block.get("filename") or src.get("name")
        if name:
            meta["name"] = name
            ext = Path(str(name)).suffix.lstrip(".").lower()
            if ext:
                meta["extension"] = ext
        data = src.get("data")
        if isinstance(data, str):
            try:
                raw = base64.b64decode(data)
            except Exception:
                raw = None
        if raw is not None:
            _meta_from_bytes(meta, raw)
        out.append(meta)
    return out


def _clean_user_text(text: str) -> str:
    """Remove agent-added upload wrappers while preserving the user's request."""
    out = text.strip()
    user_query = re.search(r"<user_query>\s*(.*?)\s*</user_query>", out, re.S)
    if user_query:
        out = user_query.group(1).strip()
    marker = "## My request for Codex:"
    if marker in out:
        out = out.split(marker, 1)[1].strip()
    out = re.sub(r"<uploaded_documents>.*?</uploaded_documents>", "", out, flags=re.S).strip()
    out = re.sub(r"<image\b[^>]*>\s*</image>", "", out, flags=re.S).strip()
    return out


def _text_from_blocks(content, *, clean_user: bool = False) -> str:
    if isinstance(content, str):
        text = content.strip()
        return _clean_user_text(text) if clean_user else text
    if not isinstance(content, list):
        return ""
    parts: list[str] = []
    for block in content:
        if isinstance(block, dict):
            if block.get("type") in ("text", "output_text", "input_text"):
                t = block.get("text", "")
                if t:
                    parts.append(str(t))
        elif isinstance(block, str) and block:
            parts.append(block)
    text = "\n".join(parts).strip()
    return _clean_user_text(text) if clean_user else text


def _is_interruption(text: str | None) -> bool:
    """Both agents record a user-stop as a synthetic user message right after the
    cut-off output: Claude ``[Request interrupted by user...]``, Codex
    ``<turn_aborted> The user interrupted the previous turn...``."""
    if not text:
        return False
    t = text.lower()
    return (
        "request interrupted by user" in t
        or "<turn_aborted>" in t
        or "interrupted the previous turn" in t
    )


def _merge_usage(acc: dict | None, usage: dict) -> dict:
    """Sum per-turn token deltas. Handles both Claude and Codex key names;
    normalize.py maps them onto the stored token columns."""
    out = dict(acc) if isinstance(acc, dict) else {}
    for key in (
        "input_tokens",
        "output_tokens",
        "cached_input_tokens",
        "cache_read_input_tokens",
        "cache_creation_input_tokens",
        "reasoning_output_tokens",
        "total_tokens",
    ):
        val = usage.get(key)
        if isinstance(val, (int, float)):
            out[key] = out.get(key, 0) + int(val)
    return out


def _read_transcript_delta(transcript_path: str, session_id: str) -> str:
    """Return newly appended transcript bytes since the last read for this session."""
    path = Path(transcript_path)
    if not path.exists():
        return ""
    offsets = _load_offsets()
    key = f"{session_id}:{transcript_path}"
    start = offsets.get(key, 0)
    try:
        text = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return ""
    if start > len(text):
        start = 0
    new_text = text[start:]
    offsets[key] = len(text)
    _save_offsets(offsets)
    return new_text


def _scan_transcript(transcript_path: str, session_id: str) -> dict:
    """Read the transcript delta once; extract assistant responses and the
    attachments (images/files) on user messages. Single read so the shared
    file offset only advances once.

    Returns {"responses": [(ts, text, model, usage, interrupted)],
    "thoughts": [(ts, text, usage, interrupted)], "attachments": [(ts, [att])]}.
    """
    empty: dict[str, list] = {"responses": [], "thoughts": [], "attachments": []}
    new_text = _read_transcript_delta(transcript_path, session_id)
    if not new_text:
        return empty

    # Ordered records so a user-stop can flag the message it cut off (the last
    # assistant thought/response before the interruption marker).
    msgs: list[dict] = []
    attachments: list[tuple] = []
    user_prompts: dict[str, str] = {}
    pending_usage: dict | None = None
    seen_msg_ids: set[str] = set()
    for line in new_text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        message = obj.get("message") if isinstance(obj.get("message"), dict) else {}
        role = obj.get("role") or message.get("role") or obj.get("type")
        content = obj.get("content")
        if content is None:
            content = message.get("content")
        ts = obj.get("timestamp")

        if role == "assistant" or obj.get("type") == "assistant":
            msg_id = message.get("id")
            if msg_id and msg_id in seen_msg_ids:
                continue
            if msg_id:
                seen_msg_ids.add(msg_id)
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "thinking":
                        think = block.get("thinking")
                        if think:
                            msgs.append({"kind": "thought", "ts": ts, "text": str(think),
                                         "model": None, "usage": None, "interrupted": False})
            text_val = _text_from_blocks(content) if isinstance(content, list) else (content or "")
            model = message.get("model") or obj.get("model")
            usage = message.get("usage") if isinstance(message.get("usage"), dict) else None
            if text_val:
                if pending_usage:
                    usage = _merge_usage(pending_usage, usage) if usage else pending_usage
                    pending_usage = None
                msgs.append({"kind": "response", "ts": ts, "text": str(text_val),
                             "model": model, "usage": usage, "interrupted": False})
            elif usage:
                pending_usage = _merge_usage(pending_usage, usage)
        elif role == "user" and isinstance(content, list):
            user_text = _text_from_blocks(content, clean_user=True)
            uuid = obj.get("uuid")
            if uuid and user_text:
                user_prompts[str(uuid)] = user_text
            if _is_interruption(user_text) and msgs:
                msgs[-1]["interrupted"] = True
            atts = _message_attachments(content)
            if atts:
                attachments.append((ts, user_text, atts))
        elif obj.get("type") == "attachment":
            att = obj.get("attachment") if isinstance(obj.get("attachment"), dict) else {}
            meta = _file_attachment_meta(att)
            parent_uuid = obj.get("parentUuid")
            parent_text = user_prompts.get(str(parent_uuid)) if parent_uuid else None
            if meta and _file_attachment_matches_text(att, parent_text):
                attachments.append((ts, parent_text, [meta]))

    if pending_usage and msgs:
        last = msgs[-1]
        last["usage"] = _merge_usage(pending_usage, last["usage"]) if last["usage"] else pending_usage

    thoughts = [(m["ts"], m["text"], m["usage"], m["interrupted"]) for m in msgs if m["kind"] == "thought"]
    responses = [(m["ts"], m["text"], m["model"], m["usage"], m["interrupted"]) for m in msgs if m["kind"] == "response"]
    return {"responses": responses, "thoughts": thoughts, "attachments": attachments}


def _scan_codex_transcript(transcript_path: str, session_id: str) -> dict:
    """Read Codex rollout JSONL deltas.

    Codex mirrors each assistant line twice (``agent_message`` then
    ``output_text`` with identical text). Only ingest the ``response_item``
    and split by ``phase``: ``commentary`` → thought, ``final_answer`` → response.
    """
    empty: dict[str, list] = {
        "thoughts": [],
        "responses": [],
        "attachments": [],
        "web_searches": [],
    }
    new_text = _read_transcript_delta(transcript_path, session_id)
    if not new_text:
        return empty

    # Each emitted assistant message gets a mutable record so we can fold the
    # per-turn ``token_count`` deltas (which arrive after the message) onto it.
    msgs: list[dict] = []
    attachments: list[tuple] = []
    web_searches: list[tuple] = []
    for line in new_text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        ts = obj.get("timestamp")
        kind = obj.get("type")
        payload = obj.get("payload") if isinstance(obj.get("payload"), dict) else {}

        if kind == "response_item":
            pt = payload.get("type")
            if pt == "message" and payload.get("role") == "assistant":
                text_val = _text_from_blocks(payload.get("content"))
                if not text_val:
                    continue
                model = payload.get("model") or obj.get("model")
                phase = payload.get("phase") or ""
                # final_answer → response; commentary / unknown phase → thought.
                msgs.append({
                    "kind": "response" if phase == "final_answer" else "thought",
                    "ts": ts,
                    "text": text_val,
                    "model": model,
                    "usage": None,
                    "interrupted": False,
                })
            elif pt == "message" and payload.get("role") == "user":
                content = payload.get("content")
                if isinstance(content, list):
                    user_text = _text_from_blocks(content, clean_user=True)
                    if _is_interruption(user_text) and msgs:
                        msgs[-1]["interrupted"] = True
                    atts = _message_attachments(content)
                    if atts:
                        attachments.append((ts, user_text, atts))
            elif pt == "web_search_call":
                action = payload.get("action") if isinstance(payload.get("action"), dict) else {}
                query = action.get("query") or payload.get("query") or ""
                if query:
                    web_searches.append((ts, str(query), action, payload.get("status")))
        elif kind == "event_msg" and payload.get("type") == "token_count":
            # Attribute the per-turn token delta to the message it followed.
            info = payload.get("info") if isinstance(payload.get("info"), dict) else {}
            last = info.get("last_token_usage") if isinstance(info.get("last_token_usage"), dict) else None
            if last and msgs:
                msgs[-1]["usage"] = _merge_usage(msgs[-1].get("usage"), last)

    thoughts = [(m["ts"], m["text"], m["usage"], m["interrupted"]) for m in msgs if m["kind"] == "thought"]
    responses = [(m["ts"], m["text"], m["model"], m["usage"], m["interrupted"]) for m in msgs if m["kind"] == "response"]
    return {
        "thoughts": thoughts,
        "responses": responses,
        "attachments": attachments,
        "web_searches": web_searches,
    }


def _emit_synthetic_messages(
    source: str,
    body: dict,
    scanned: dict,
) -> None:
    session_id = body.get("session_id")
    if not session_id:
        return
    for ts, text, atts in scanned.get("attachments", []):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "_attach_to_prompt": True,
                "text": text,
                "attachments": atts,
                "timestamp": ts or body.get("timestamp"),
            },
        )
    for ts, msg, usage, interrupted in scanned.get("thoughts", []):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "hook_event_name": "afterAgentThought",
                "thought": msg,
                "_synthetic_category": "thought",
                "timestamp": ts or body.get("timestamp"),
                "model": body.get("model"),
                "usage": usage,
                "interrupted": interrupted,
            },
        )
    for ts, msg, model, usage, interrupted in scanned.get("responses", []):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "hook_event_name": "afterAgentResponse",
                "response": msg,
                "_synthetic_category": "response",
                "timestamp": ts or body.get("timestamp"),
                "model": model or body.get("model"),
                "usage": usage,
                "interrupted": interrupted,
            },
        )
    for ts, query, action, status in scanned.get("web_searches", []):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "hook_event_name": "PostToolUse",
                "tool_name": "WebSearch",
                "tool_input": {"query": query, "queries": action.get("queries", [])},
                "tool_response": {"status": status, "action": action},
                "timestamp": ts or body.get("timestamp"),
                "model": body.get("model"),
            },
        )


def _emit_claude_responses(body: dict, source: str) -> None:
    hook = body.get("hook_event_name") or body.get("hook") or ""
    if hook not in ("Stop", "SubagentStop"):
        return
    transcript = body.get("transcript_path")
    session_id = body.get("session_id")
    if not transcript or not session_id:
        return
    scanned = _scan_transcript(transcript, session_id)
    _emit_synthetic_messages(source, body, scanned)


def _norm_choice(text: object) -> str:
    return " ".join(str(text or "").lower().replace("_", " ").split())


def _contains_positive(haystack: str, needle: str) -> bool:
    if not needle:
        return False
    start = haystack.find(needle)
    if start < 0:
        return False
    before = haystack[max(0, start - 24) : start].split()
    return not any(tok in {"no", "not", "without"} for tok in before[-3:])


def _choice_matches(label: str, option_id: str, response_text: str) -> bool:
    haystack = _norm_choice(response_text)
    candidates = [label, label.split(" (", 1)[0]]
    if " for now" in label:
        candidates.append(label.split(" for now", 1)[0])
    if " — " in label:
        candidates.append(label.split(" — ", 1)[0])
    if any(len(_norm_choice(c)) >= 4 and _contains_positive(haystack, _norm_choice(c)) for c in candidates):
        return True
    oid = _norm_choice(option_id.replace("_", " "))
    # Short ids are often common words ("accept", "keep") that match prose by
    # coincidence; require a reasonably long id to avoid false positives.
    if len(oid) >= 8 and _contains_positive(haystack, oid):
        return True
    return False


# Match window: the agent states its choice up front; the deliberation tail
# re-mentions every option and only adds ambiguity. Kept in sync with db.py.
_ANSWER_REGION_CHARS = 700


def _answer_region(text: str) -> str:
    region = str(text or "").strip()
    markers = (
        "\n---",
        "\n## Full picture",
        "\n## Suggested",
        "\n**Suggested roadmap",
        "\n**Still unanswered",
        "\n**Two optional follow-ups",
    )
    for marker in markers:
        idx = region.find(marker)
        if idx >= 0:
            region = region[:idx]
    return region[:_ANSWER_REGION_CHARS]


# Kept in sync with backend/app/db.py: recover a paraphrased AskQuestion
# selection from the agent's follow-up prose when strict label matching misses.
_TITLE_STOPWORDS = frozenset(
    {
        "the", "a", "an", "and", "or", "then", "with", "your", "you", "for",
        "now", "via", "use", "using", "run", "not", "but", "its", "this",
        "that", "into", "etc", "all", "any", "per", "are", "was", "will",
    }
)


def _option_title(label: str) -> str:
    t = str(label or "")
    for sep in (":", " — ", " - ", " ("):
        if sep in t:
            t = t.split(sep, 1)[0]
    return t.strip()


def _word_tokens(text: str) -> list[str]:
    return [w for w in re.split(r"[^a-z0-9]+", str(text or "").lower()) if w]


def _title_tokens(title: str) -> list[str]:
    return [w for w in _word_tokens(title) if len(w) >= 3 and w not in _TITLE_STOPWORDS]


def _token_present(tok: str, resp_tokens: list[str]) -> bool:
    for rt in resp_tokens:
        if len(rt) < 3:
            continue
        if rt.startswith(tok) or tok.startswith(rt):
            return True
    return False


_TITLE_MATCH_MIN_RATIO = 0.6


def _unique_title_match(options: list, match_text: str, min_margin: float = 0.2) -> str | None:
    """Commit to the top option only when it clears the ratio bar AND beats the
    runner-up by ``min_margin`` — so a short generic label can't edge out the
    real answer, and near-ties abstain. Kept in sync with db.py."""
    resp_tokens = _word_tokens(match_text)
    if not resp_tokens:
        return None
    scored: list = []
    for opt in options:
        if not isinstance(opt, dict):
            continue
        label = str(opt.get("label") or "").strip()
        oid = str(opt.get("id") or "").strip()
        tt = _title_tokens(_option_title(label))
        if len(tt) < 2:
            scored.append((0.0, 0, label or oid))
            continue
        present = sum(1 for t in tt if _token_present(t, resp_tokens))
        scored.append((present / len(tt), present, label or oid))
    if not scored:
        return None
    scored.sort(key=lambda x: (-x[0], -x[1]))
    best_ratio, best_present, best_label = scored[0]
    second_ratio = scored[1][0] if len(scored) > 1 else 0.0
    if (
        best_present >= 2
        and best_ratio >= _TITLE_MATCH_MIN_RATIO
        and best_ratio - second_ratio >= min_margin
    ):
        return best_label
    return None


_DECISION_ANCHORS = re.compile(
    r"\b(?:went with|going with|go with|i'?ll go with|let'?s go with|you chose|"
    r"i chose|we chose|chose|settling on|settle on|decided (?:on|to)|decided|"
    r"picked|selected|opting for|opted for)\b"
    r"|^\s*(?:got it|ok|okay|sounds good|perfect|great)\b[\s,:\u2014-]",
    re.I | re.M,
)
_DECISION_SPAN_CHARS = 200


def _decision_region(text: str) -> str:
    s = str(text or "")
    spans = [s[m.start() : m.start() + _DECISION_SPAN_CHARS] for m in _DECISION_ANCHORS.finditer(s)]
    return " ".join(spans)


def _match_question(options: list, region: str, min_margin: float = 0.2) -> list:
    labels: list = []
    for opt in options:
        if not isinstance(opt, dict):
            continue
        label = str(opt.get("label") or "").strip()
        oid = str(opt.get("id") or "").strip()
        if _choice_matches(label, oid, region):
            labels.append(label or oid)
    if not labels:
        single = _unique_title_match(options, region, min_margin)
        if single:
            labels = [single]
    return labels


def _cursor_question_response(tool_input: dict, response_text: str) -> dict:
    """Best-effort recovery for Cursor AskQuestion selections.

    Cursor records the question prompt as an ``AskQuestion`` transcript tool_use,
    but does not persist a separate tool_result in the JSONL. The next assistant
    response usually summarizes selected options and says which batches were
    skipped/open. We only match explicit option labels/ids in that summary; no
    free-form guessing.
    """
    questions = tool_input.get("questions") if isinstance(tool_input.get("questions"), list) else []
    answer_region = _answer_region(response_text)
    decision_region = _decision_region(response_text)
    haystack = _norm_choice(response_text)
    mentions_skip = any(word in haystack for word in ("skipped", "unanswered", "still open"))
    answers: dict[str, dict[str, list[str]]] = {}
    skipped: list[str] = []

    for q in questions:
        if not isinstance(q, dict):
            continue
        qid = str(q.get("id") or "")
        if not qid:
            continue
        options = q.get("options") if isinstance(q.get("options"), list) else []
        labels = _match_question(options, decision_region, 0.15) if decision_region else []
        if not labels:
            labels = _match_question(options, answer_region, 0.25)
        if labels:
            answers[qid] = {"answers": labels}
        elif mentions_skip:
            skipped.append(qid)

    out: dict = {}
    if answers:
        out["answers"] = answers
        out["answer_source"] = "assistant_summary"
    if skipped:
        out["skipped"] = skipped
    return out


def _scan_cursor_artifacts(transcript_path: str, session_id: str, response_text: str = "") -> dict:
    """Extract Cursor transcript-only artifacts.

    In plan mode Cursor generates the plan through an internal ``CreatePlan``
    tool that fires no tool hooks; ``afterAgentResponse`` then arrives with empty
    text. Cursor question prompts similarly appear as ``AskQuestion`` tool_use
    blocks without pre/post tool hooks. Recover both in one transcript pass so
    one artifact scanner does not consume another scanner's offset."""
    new_text = _read_transcript_delta(transcript_path, session_id)
    out: dict[str, list] = {"plans": [], "questions": [], "attachments": [], "responses": []}
    if not new_text:
        return out
    plans: list[dict] = []
    questions: list[dict] = []
    attachments: list[tuple] = []
    responses: list[str] = []
    for line in new_text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        message = obj.get("message") if isinstance(obj.get("message"), dict) else {}
        content = obj.get("content")
        if content is None:
            content = message.get("content")
        if not isinstance(content, list):
            continue
        role = obj.get("role") or message.get("role") or obj.get("type")
        if role == "user":
            atts = _message_attachments(content)
            if atts:
                attachments.append((obj.get("timestamp"), _text_from_blocks(content, clean_user=True), atts))
        for block in content:
            if not isinstance(block, dict):
                continue
            # Cursor's afterAgentResponse hook only delivers the final text per
            # turn, so the intermediate commentary between tool calls lives only
            # here. Collect every assistant text block, in order.
            if block.get("type") == "text" and role == "assistant":
                t = str(block.get("text") or "").strip()
                if t:
                    responses.append(t)
                continue
            if block.get("type") != "tool_use":
                continue
            name = block.get("name")
            if name == "CreatePlan":
                inp = block.get("input") if isinstance(block.get("input"), dict) else {}
                plans.append(
                    {
                        "name": inp.get("name") or "Plan",
                        "overview": inp.get("overview") or "",
                        "plan": inp.get("plan") or "",
                        "todos": inp.get("todos") if isinstance(inp.get("todos"), list) else [],
                    }
                )
            elif name == "AskQuestion":
                inp = block.get("input") if isinstance(block.get("input"), dict) else {}
                questions.append(
                    {
                        "input": inp,
                        "response": _cursor_question_response(inp, response_text),
                    }
                )
    out["plans"] = plans
    out["questions"] = questions
    out["attachments"] = attachments
    out["responses"] = responses
    return out


def _emit_cursor_artifacts(body: dict, source: str) -> bool:
    """Recover Cursor artifacts that are present only in transcript JSONL.

    Returns True when this was a plan turn and the function has already posted
    both the (text-filled) response and a structured plan event, so the caller
    skips the default post."""
    hook = body.get("hook_event_name") or body.get("hook") or ""
    # afterAgentResponse carries the turn-final text; stop is a backstop that
    # flushes any transcript text written after the last afterAgentResponse.
    if hook not in ("afterAgentResponse", "stop"):
        return False
    transcript = body.get("transcript_path")
    session_id = body.get("session_id")
    if not transcript or not session_id:
        return False
    scanned = _scan_cursor_artifacts(transcript, session_id, str(body.get("text") or body.get("response") or ""))
    plans = scanned.get("plans", [])
    questions = scanned.get("questions", [])
    for ts, text, atts in scanned.get("attachments", []):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "_attach_to_prompt": True,
                "text": text,
                "attachments": atts,
                "timestamp": ts or body.get("timestamp"),
            },
        )
    for q in questions:
        for hook_name, response in (("preToolUse", {}), ("postToolUse", q["response"])):
            _post(
                f"{COT_ENDPOINT}/v1/ingest/{source}",
                {
                    "session_id": session_id,
                    "cwd": body.get("cwd"),
                    "hook_event_name": hook_name,
                    "tool_name": "AskQuestion",
                    "tool_input": q["input"],
                    "tool_response": response,
                    "composer_mode": body.get("composer_mode"),
                    "model": body.get("model"),
                    "timestamp": body.get("timestamp"),
                },
            )
    # Emit every assistant text block from the transcript delta. Cursor's
    # afterAgentResponse hook carries only the turn-final text, so this is the
    # only place the intermediate commentary is available.
    # Deduplicate consecutive identical texts: Cursor transcripts often repeat
    # the same brief commentary across many assistant messages within a turn
    # (e.g. 56 identical blocks), and the final response can appear twice.
    responses = scanned.get("responses", [])
    deduped: list[str] = []
    for r in responses:
        if not deduped or _norm_choice(deduped[-1]) != _norm_choice(r):
            deduped.append(r)
    body_text = str(body.get("text") or body.get("response") or "").strip()
    emit_list = list(deduped)
    # Safety net: if the hook's final text wasn't in the delta yet, include it
    # (deduped against the last transcript block).
    if body_text and (not emit_list or _norm_choice(emit_list[-1]) != _norm_choice(body_text)):
        emit_list.append(body_text)
    for i, text in enumerate(emit_list):
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "hook_event_name": "afterAgentResponse",
                "_synthetic_category": "response",
                "response": text,
                "composer_mode": body.get("composer_mode"),
                "model": body.get("model"),
                "timestamp": _ordered_ts(body.get("timestamp"), i),
            },
        )

    # Structured plan artifact (name + overview + todo checklist). A distinct
    # hook name routes it via _synthetic_category, not afterAgentResponse.
    for p in plans:
        _post(
            f"{COT_ENDPOINT}/v1/ingest/{source}",
            {
                "session_id": session_id,
                "cwd": body.get("cwd"),
                "hook_event_name": "createPlan",
                "_synthetic_category": "plan",
                "plan_name": p["name"],
                "plan_overview": p["overview"],
                "plan_body": p["plan"],
                "plan_todos": p["todos"],
                "composer_mode": "plan",
                "model": body.get("model"),
                "timestamp": body.get("timestamp"),
            },
        )

    # Plan-only turn with no text response: surface the plan body so the
    # conversation view isn't blank.
    if plans and not emit_list:
        last = plans[-1]
        plan_text = last.get("plan") or last.get("overview") or ""
        if plan_text:
            _post(
                f"{COT_ENDPOINT}/v1/ingest/{source}",
                {
                    "session_id": session_id,
                    "cwd": body.get("cwd"),
                    "hook_event_name": "afterAgentResponse",
                    "_synthetic_category": "response",
                    "response": plan_text,
                    "composer_mode": "plan",
                    "model": body.get("model"),
                    "timestamp": body.get("timestamp"),
                },
            )
            emit_list.append(plan_text)

    # On 'stop', let the caller still post the lifecycle "Session ended" body —
    # we only emitted responses here, which don't duplicate it.
    if hook == "stop":
        return False
    # On afterAgentResponse we've emitted the response(s) ourselves; tell the
    # caller to skip the default body post (which would duplicate the final).
    # Only when we emitted nothing do we let the caller post the raw body.
    return bool(emit_list or plans)


def _find_codex_transcript(session_id: str) -> str | None:
    """Locate a Codex rollout transcript from the session id alone.

    Codex only includes ``transcript_path`` on some hook payloads (it varies by
    version/hook), but the session id is always present and is the suffix of the
    rollout filename: ``rollout-<timestamp>-<session_id>.jsonl``. Deriving the
    path here means intermediate thinking is captured regardless of payload shape.
    """
    if not session_id:
        return None
    base = STATE_DIR.parent / ".codex" / "sessions"
    if not base.exists():
        return None
    matches = list(base.glob(f"**/rollout-*-{session_id}.jsonl"))
    if not matches:
        matches = list(base.glob(f"**/*{session_id}*.jsonl"))
    if not matches:
        return None
    return str(max(matches, key=lambda p: p.stat().st_mtime))


def _emit_codex_responses(body: dict, source: str) -> None:
    """Codex stores commentary and assistant text in rollout JSONL transcripts.

    Scan the transcript so intermediate thoughts, responses, web searches, and
    token usage appear while the turn is in progress. The transcript is located
    from the session id when the hook payload omits ``transcript_path``. Fall
    back to ``last_assistant_message`` on Stop when the transcript can't be read.
    """
    session_id = body.get("session_id")
    transcript = body.get("transcript_path") or _find_codex_transcript(session_id)
    hook = body.get("hook_event_name") or body.get("hook") or ""

    scanned: dict = {"thoughts": [], "responses": [], "attachments": [], "web_searches": []}
    if transcript and session_id:
        scanned = _scan_codex_transcript(transcript, session_id)
        _emit_synthetic_messages(source, body, scanned)

    # Fallback only when no transcript could be read at all. When a transcript
    # was scanned it is authoritative: the final answer is already emitted (here
    # or on an earlier hook), so adding last_assistant_message would duplicate it
    # — the per-scan ``responses`` check can't see the earlier emit.
    if hook in ("Stop", "SubagentStop") and session_id and not transcript:
        msg = body.get("last_assistant_message")
        if msg:
            _post(
                f"{COT_ENDPOINT}/v1/ingest/{source}",
                {
                    "session_id": session_id,
                    "cwd": body.get("cwd"),
                    "hook_event_name": "afterAgentResponse",
                    "response": msg,
                    "_synthetic_category": "response",
                    "timestamp": body.get("timestamp"),
                    "model": body.get("model"),
                },
            )


def _hook_response(source: str, body: dict) -> dict | None:
    hook = body.get("hook_event_name") or body.get("hook") or body.get("event") or ""
    if source == "cursor":
        if hook in CURSOR_ALLOW_HOOKS:
            return {"permission": "allow"}
        return {"continue": True}
    if source == "codex":
        # Codex's hook engine rejects the {continue, suppressOutput} envelope on
        # tool-use events and marks the run "Failed". Emit nothing there (exit 0
        # with no output is a pass); for the rest, the passive continue is fine.
        if hook in ("PreToolUse", "PostToolUse", "PermissionRequest"):
            return None
        return {"continue": True}
    return {"continue": True, "suppressOutput": True}


def _log_launch(body: dict) -> None:
    """Debug aid: record the process tree that started a Claude session, so we
    can see what spawns the empty home-directory sessions."""
    try:
        import subprocess

        STATE_DIR.mkdir(parents=True, exist_ok=True)
        log = STATE_DIR / "session-launches.log"
        lines = [
            f"=== {body.get('timestamp') or ''} session={body.get('session_id')} "
            f"source={body.get('source')} cwd={body.get('cwd')}"
        ]
        pid = os.getppid()  # the claude process that ran this hook
        for _ in range(8):
            if pid <= 1:
                break
            row = subprocess.run(
                ["ps", "-o", "pid=,ppid=,command=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2,
            ).stdout.strip()
            if not row:
                break
            lines.append("  " + row)
            ppid = subprocess.run(
                ["ps", "-o", "ppid=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2,
            ).stdout.strip()
            pid = int(ppid) if ppid.isdigit() else 0
        with log.open("a", encoding="utf-8") as f:
            f.write("\n".join(lines) + "\n")
    except Exception:
        pass


AGENTS = ("claude", "cursor", "codex")

# Where each agent reads its hook config, and whether it is a Cursor-style file
# (a top-level "version" alongside "hooks") vs. a Claude/Codex-style file.
_CONFIG_TARGETS = {
    "claude": (Path.home() / ".claude" / "settings.json", False),
    "cursor": (Path.home() / ".cursor" / "hooks.json", True),
    "codex": (Path.home() / ".codex" / "hooks.json", False),
}


def _hook_command(agent: str) -> str:
    """Portable bridge path — agents expand ``$HOME`` when invoking hook commands."""
    return f"$HOME/.cot/bin/cot hook {agent}"


def _cot_hook_signature(agent: str) -> str:
    """Stable substring for detecting cot hook wiring without false positives."""
    return f".cot/bin/cot hook {agent}"


def _hook_commands_in_entry(entry: dict) -> list[str]:
    cmds: list[str] = []
    if not isinstance(entry, dict):
        return cmds
    for hook in entry.get("hooks") or []:
        if isinstance(hook, dict) and isinstance(hook.get("command"), str):
            cmds.append(hook["command"])
    if isinstance(entry.get("command"), str):
        cmds.append(entry["command"])
    return cmds


def _entry_has_cot_hook(entry: dict, agent: str) -> bool:
    sig = _cot_hook_signature(agent)
    return any(sig in cmd for cmd in _hook_commands_in_entry(entry))


def _entries_have_cot_hook(entries: list, agent: str) -> bool:
    return any(_entry_has_cot_hook(entry, agent) for entry in entries if isinstance(entry, dict))


def _normalize_cot_hooks(entries: list, agent: str) -> list:
    """Rewrite any cot hook command to the canonical ``$HOME`` form."""
    cmd = _hook_command(agent)
    sig = _cot_hook_signature(agent)
    out: list = []
    for entry in entries:
        if not isinstance(entry, dict):
            out.append(entry)
            continue
        if not _entry_has_cot_hook(entry, agent):
            out.append(entry)
            continue
        new_entry = dict(entry)
        if "hooks" in new_entry:
            new_hooks = []
            for hook in new_entry.get("hooks") or []:
                if not isinstance(hook, dict):
                    new_hooks.append(hook)
                    continue
                hook_cmd = hook.get("command", "")
                if isinstance(hook_cmd, str) and sig in hook_cmd:
                    new_hooks.append({**hook, "command": cmd})
                else:
                    new_hooks.append(hook)
            new_entry["hooks"] = new_hooks
        elif isinstance(new_entry.get("command"), str) and sig in new_entry["command"]:
            new_entry["command"] = cmd
        out.append(new_entry)
    return out


def _claude_style_hooks(agent: str, events: list[tuple[str, bool]]) -> dict:
    """Claude/Codex hook shape: each event maps to a list of groups, each with a
    `hooks` array of command entries (and an optional tool `matcher`)."""
    cmd = _hook_command(agent)
    out: dict[str, list] = {}
    for name, matcher in events:
        group: dict = {"hooks": [{"type": "command", "command": cmd}]}
        if matcher:
            group = {"matcher": "*", **group}
        out[name] = [group]
    return out


def _hook_templates() -> dict[str, dict]:
    return {
        "claude": _claude_style_hooks(
            "claude",
            [
                ("SessionStart", False),
                ("SessionEnd", False),
                ("UserPromptSubmit", False),
                ("PreToolUse", True),
                ("PostToolUse", True),
                ("PostToolUseFailure", True),
                ("Stop", False),
                ("SubagentStop", False),
                ("PreCompact", False),
                ("Notification", False),
            ],
        ),
        "codex": _claude_style_hooks(
            "codex",
            [
                ("SessionStart", False),
                ("UserPromptSubmit", False),
                ("PreToolUse", True),
                ("PostToolUse", True),
                ("PermissionRequest", True),
                ("PreCompact", False),
                ("PostCompact", False),
                ("SubagentStart", True),
                ("SubagentStop", True),
                ("Stop", False),
            ],
        ),
        # Cursor fires both granular hooks (beforeShellExecution, afterFileEdit,
        # before/afterMCPExecution, beforeReadFile) AND generic pre/postToolUse
        # for the same action. The generic pair carries the richest, most uniform
        # payload (tool_input, tool_output, duration, model) and fires for *every*
        # tool — shell, read, edit, search, subagent, delete, web, and MCP — so we
        # wire only those and skip the granular duplicates to avoid double-counting.
        "cursor": {
            name: [{"command": _hook_command("cursor")}]
            for name in (
                "sessionStart",
                "sessionEnd",
                "beforeSubmitPrompt",
                "afterAgentResponse",
                "afterAgentThought",
                "preToolUse",
                "postToolUse",
                "postToolUseFailure",
                "subagentStart",
                "subagentStop",
                "preCompact",
                "stop",
            )
        },
    }


def _template_events(template: dict) -> list[str]:
    return list(template.keys())


def _read_json_file(path: Path) -> tuple[dict, str | None]:
    try:
        parsed = json.loads(path.read_text() or "{}")
    except FileNotFoundError:
        return {}, "missing"
    except json.JSONDecodeError as exc:
        return {}, f"invalid json: {exc}"
    except OSError as exc:
        return {}, str(exc)
    if not isinstance(parsed, dict):
        return {}, "json root is not an object"
    return parsed, None


def _read_backup_manifest() -> dict:
    data, err = _read_json_file(HOOK_BACKUPS_PATH)
    if err:
        return {"entries": []}
    entries = data.get("entries")
    return {"entries": entries if isinstance(entries, list) else []}


def _write_backup_manifest(manifest: dict) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    manifest["updated_at"] = _now_z()
    HOOK_BACKUPS_PATH.write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + "\n")


def _backup_entries(agent: str) -> list[dict]:
    entries = _read_backup_manifest().get("entries", [])
    return [e for e in entries if isinstance(e, dict) and e.get("agent") == agent]


def _latest_backup(agent: str) -> dict | None:
    entries = _backup_entries(agent)
    if not entries:
        return None
    return sorted(entries, key=lambda e: str(e.get("created_at") or ""))[-1]


def _backup_config(agent: str, path: Path, action: str) -> dict | None:
    if not path.exists():
        return None
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    backup = path.with_name(f"{path.name}.cot-{stamp}.bak")
    shutil.copy2(path, backup)
    entry = {
        "agent": agent,
        "config_path": str(path),
        "backup_path": str(backup),
        "created_at": _now_z(),
        "action": action,
        "endpoint": COT_ENDPOINT,
    }
    manifest = _read_backup_manifest()
    manifest.setdefault("entries", []).append(entry)
    _write_backup_manifest(manifest)
    _audit_self(
        "bridge.hooks.backup_created",
        target=agent,
        detail=entry,
    )
    return entry


def _agent_hook_status(agent: str) -> dict:
    path, _ = _CONFIG_TARGETS[agent]
    expected = _template_events(_hook_templates()[agent])
    config, err = _read_json_file(path)
    exists = path.exists()
    valid_json = err is None
    hooks = config.get("hooks") if isinstance(config.get("hooks"), dict) else {}
    installed_hooks: list[str] = []
    if valid_json:
        for name in expected:
            entries = hooks.get(name)
            if isinstance(entries, list) and _entries_have_cot_hook(entries, agent):
                installed_hooks.append(name)
    missing_hooks = [name for name in expected if name not in installed_hooks]
    latest = _latest_backup(agent)
    backups = _backup_entries(agent)
    warnings: list[str] = []
    if not exists:
        warnings.append("config_missing")
    elif not valid_json:
        warnings.append("config_invalid")
    if missing_hooks:
        warnings.append("hooks_missing")
    return {
        "agent": agent,
        "config_path": str(path),
        "config_exists": exists,
        "valid_json": valid_json,
        "error": None if err == "missing" else err,
        "installed": valid_json and not missing_hooks,
        "expected_hooks": expected,
        "installed_hooks": installed_hooks,
        "missing_hooks": missing_hooks,
        "backup_count": len(backups),
        "latest_backup": latest,
        "warnings": warnings,
    }


def _merge_hooks(existing: dict, template: dict, agent: str) -> dict:
    """Add cot's command for each event without disturbing the user's own hooks.
    Idempotent: if cot is already wired into an event, normalize its command;
    otherwise append cot alongside any existing hooks."""
    merged = dict(existing) if isinstance(existing, dict) else {}
    for event, entries in template.items():
        current = merged.get(event)
        if not isinstance(current, list):
            current = []
        if _entries_have_cot_hook(current, agent):
            merged[event] = _normalize_cot_hooks(current, agent)
        else:
            merged[event] = current + entries
    return merged


def _remove_hooks(existing: dict, agent: str) -> dict:
    """Remove only cot hook entries, preserving any user-managed hooks."""
    cleaned = dict(existing) if isinstance(existing, dict) else {}
    for event, entries in list(cleaned.items()):
        if not isinstance(entries, list):
            continue
        kept = [entry for entry in entries if not _entry_has_cot_hook(entry, agent)]
        if kept:
            cleaned[event] = kept
        else:
            cleaned.pop(event, None)
    return cleaned


def _hooks_installed(agent: str) -> bool:
    return bool(_agent_hook_status(agent)["installed"])


def _install_agent(agent: str, action: str = "install") -> dict:
    path, cursor_style = _CONFIG_TARGETS[agent]
    template = _hook_templates()[agent]

    config, err = _read_json_file(path)
    if err == "missing":
        config = {}

    existing = config.get("hooks") if isinstance(config.get("hooks"), dict) else {}
    next_config = dict(config)
    next_config["hooks"] = _merge_hooks(existing, template, agent)
    if cursor_style:
        next_config.setdefault("version", 1)
    changed = next_config != config or err not in (None, "missing")
    backup = None
    if changed:
        path.parent.mkdir(parents=True, exist_ok=True)
        backup = _backup_config(agent, path, action)
        path.write_text(json.dumps(next_config, indent=2) + "\n")
    status = _agent_hook_status(agent)
    status.update(
        {
            "changed": changed,
            "backup_created": backup,
            "status": "ok",
        }
    )
    return status


def _uninstall_agent(agent: str, action: str = "uninstall") -> dict:
    path, _ = _CONFIG_TARGETS[agent]
    config, err = _read_json_file(path)
    if err == "missing":
        return {
            "agent": agent,
            "config_path": str(path),
            "changed": False,
            "backup_created": None,
            "status": "ok",
        }
    if err:
        return {
            "agent": agent,
            "config_path": str(path),
            "changed": False,
            "backup_created": None,
            "status": "error",
            "error": err,
        }

    existing = config.get("hooks") if isinstance(config.get("hooks"), dict) else {}
    next_config = dict(config)
    next_hooks = _remove_hooks(existing, agent)
    if next_hooks:
        next_config["hooks"] = next_hooks
    else:
        next_config.pop("hooks", None)

    changed = next_config != config
    backup = None
    if changed:
        backup = _backup_config(agent, path, action)
        path.write_text(json.dumps(next_config, indent=2) + "\n")
    return {
        "agent": agent,
        "config_path": str(path),
        "changed": changed,
        "backup_created": backup,
        "status": "ok",
    }


def _write_hook_status() -> None:
    """Record installed hook status where the collector can read it.

    The collector runs in Docker with ~/.cot mounted, so it cannot inspect
    ~/.claude, ~/.cursor, or ~/.codex directly. This manifest is the bridge's
    small, content-free handoff to the dashboard.
    """
    status = {
        "updated_at": _now_z(),
        "endpoint": COT_ENDPOINT,
        "agents": {agent: _agent_hook_status(agent) for agent in AGENTS},
    }
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    HOOK_STATUS_PATH.write_text(json.dumps(status, indent=2) + "\n")


def _cmd_install(args: list[str]) -> int:
    agents = [a for a in args if a in AGENTS]
    if not agents:
        agents = list(AGENTS)
    repair = os.environ.get("COT_REPAIR") in ("1", "true", "yes")
    action = "repair" if repair else "install"
    results: list[dict] = []
    for agent in agents:
        try:
            result = _install_agent(agent, action=action)
            results.append(result)
            verb = "repaired" if repair else "wired up"
            print(f"cot: {verb} {agent} hooks -> {result['config_path']}")
            if result.get("backup_created"):
                print(f"cot: backup saved -> {result['backup_created']['backup_path']}")
            elif not result.get("changed"):
                print(f"cot: {agent} hooks already up to date")
        except OSError as exc:
            results.append(
                {
                    "agent": agent,
                    "config_path": str(_CONFIG_TARGETS[agent][0]),
                    "status": "error",
                    "error": str(exc),
                }
            )
            print(f"cot: failed to wire up {agent}: {exc}", file=sys.stderr)
    try:
        _write_hook_status()
        status_written = True
    except OSError as exc:
        status_written = False
        print(f"cot: failed to write hook status: {exc}", file=sys.stderr)
    audit_detail = {
        "agents": [
            {
                "agent": r.get("agent") or r.get("target"),
                "config_path": r.get("config_path"),
                "status": r.get("status"),
                "changed": r.get("changed"),
                "missing_hooks": r.get("missing_hooks"),
                "backup_path": (r.get("backup_created") or {}).get("backup_path")
                if isinstance(r.get("backup_created"), dict)
                else None,
            }
            for r in results
        ],
        "hook_status_path": str(HOOK_STATUS_PATH),
        "hook_status_written": status_written,
        "endpoint": COT_ENDPOINT,
    }
    _audit_self(
        "bridge.hooks.repaired" if repair else "bridge.hooks.installed",
        target="hooks",
        status="ok" if all(r["status"] == "ok" for r in results) and status_written else "error",
        detail=audit_detail,
    )
    if "codex" in agents:
        print("cot: run /hooks in Codex to review and trust the new hooks.")

    # Auto-import historical transcripts after hook setup.
    print("cot: importing historical transcripts…")
    try:
        _reindex_if_parser_changed()
        origins = _fetch_session_origins()
        offsets = _import_offsets_load()
        total = 0
        for agent in agents:
            count = _import_agent(agent, None, offsets, origins, verbose=False)
            total += count
        _import_offsets_save(offsets)
        _write_import_parser_version()
        if total:
            try:
                req = urllib.request.Request(
                    f"{COT_ENDPOINT}/v1/sessions/complete-imported",
                    method="POST",
                    headers={"Content-Type": "application/json"},
                    data=b"{}",
                )
                urllib.request.urlopen(req, timeout=10)
            except (urllib.error.URLError, TimeoutError, OSError):
                pass
            print(f"cot: imported {total} events from existing transcripts")
        else:
            print("cot: no new transcripts to import")
    except Exception as exc:
        print(f"cot: transcript import skipped ({exc})", file=sys.stderr)

    # Recover AskQuestion answers from the transcripts (best-effort).
    try:
        recovered = _recover_questions()
        if recovered:
            print(f"cot: recovered {recovered} question answer(s)")
    except Exception:
        pass

    return 0


def _cmd_status() -> int:
    status = {agent: _hooks_installed(agent) for agent in AGENTS}
    print(json.dumps({"endpoint": COT_ENDPOINT, "hooks": status}, indent=2))
    return 0


def _container_name() -> str:
    return os.environ.get("COT_CONTAINER") or "cot"


def _docker_available() -> bool:
    return shutil.which("docker") is not None


def _docker_container_names(*filters: str) -> tuple[list[str], str | None]:
    result = subprocess.run(
        ["docker", "ps", "-a", *filters, "--format", "{{.Names}}"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return [], (result.stderr or result.stdout).strip() or "Could not query Docker containers."
    return [line for line in result.stdout.splitlines() if line], None


def _collector_container_names(container: str) -> tuple[list[str], str | None]:
    names, err = _docker_container_names()
    if err:
        return [], err
    targets: list[str] = []
    if container in names:
        targets.append(container)
    if container == "cot":
        compose_names, err = _docker_container_names(
            "--filter", "label=com.docker.compose.project=cot"
        )
        if err:
            return [], err
        for name in compose_names:
            if name not in targets:
                targets.append(name)
    return targets, None


def _docker_rm_collector(container: str) -> tuple[bool, str]:
    if not _docker_available():
        return False, "Docker is not installed or not on PATH."
    targets, err = _collector_container_names(container)
    if err:
        return False, err
    if not targets:
        return True, f"No cot collector containers found for {container}."
    result = subprocess.run(["docker", "rm", "-f", *targets], capture_output=True, text=True)
    output = (result.stdout or result.stderr).strip()
    if result.returncode == 0:
        return True, f"Removed cot collector container(s): {', '.join(targets)}"
    return False, output or f"Could not remove cot collector container(s): {', '.join(targets)}"


def _docker_running_map(targets: list[str]) -> tuple[dict[str, bool], str | None]:
    if not targets:
        return {}, None
    result = subprocess.run(
        ["docker", "inspect", "--format", "{{.Name}}\t{{.State.Running}}", *targets],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return {}, (result.stderr or result.stdout).strip() or "Could not inspect cot containers."
    states: dict[str, bool] = {}
    for line in result.stdout.splitlines():
        name, _, running = line.partition("\t")
        states[name.lstrip("/")] = running.strip().lower() == "true"
    return states, None


def _docker_start_collectors(container: str) -> tuple[bool, str]:
    if not _docker_available():
        return False, "Docker is not installed or not on PATH."
    targets, err = _collector_container_names(container)
    if err:
        return False, err
    if not targets:
        return False, ""
    states, err = _docker_running_map(targets)
    if err:
        return False, err
    stopped = [name for name in targets if not states.get(name, False)]
    if not stopped:
        return True, f"cot collector already running: {', '.join(targets)}"
    result = subprocess.run(["docker", "start", *stopped], capture_output=True, text=True)
    output = (result.stdout or result.stderr).strip()
    if result.returncode == 0:
        return True, f"Started cot collector container(s): {', '.join(stopped)}"
    return False, output or f"Could not start cot collector container(s): {', '.join(stopped)}"


def _docker_stop_collectors(container: str) -> tuple[bool, str]:
    if not _docker_available():
        return False, "Docker is not installed or not on PATH."
    targets, err = _collector_container_names(container)
    if err:
        return False, err
    if not targets:
        return True, f"No cot collector containers found for {container}."
    states, err = _docker_running_map(targets)
    if err:
        return False, err
    running = [name for name in targets if states.get(name, False)]
    if not running:
        return True, f"cot collector already stopped: {', '.join(targets)}"
    result = subprocess.run(["docker", "stop", *running], capture_output=True, text=True)
    output = (result.stdout or result.stderr).strip()
    if result.returncode == 0:
        return True, f"Stopped cot collector container(s): {', '.join(running)}"
    return False, output or f"Could not stop cot collector container(s): {', '.join(running)}"


def _endpoint_port(endpoint: str) -> int:
    try:
        parsed = urllib.parse.urlparse(endpoint)
        return int(parsed.port or DEFAULT_ENDPOINT.rsplit(":", 1)[1])
    except (TypeError, ValueError):
        return 31337


def _endpoint_for_port(port: int) -> str:
    return f"http://127.0.0.1:{port}"


def _port_in_use(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.2)
        return sock.connect_ex(("127.0.0.1", port)) == 0


def _write_endpoint_config(endpoint: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps({"endpoint": endpoint}) + "\n")


def _wait_for_health(endpoint: str, attempts: int = 60) -> bool:
    for _ in range(attempts):
        try:
            urllib.request.urlopen(f"{endpoint}/health", timeout=1).read()
            return True
        except (urllib.error.URLError, TimeoutError, OSError):
            import time
            time.sleep(1)
    return False


def _docker_run_collector(container: str) -> tuple[bool, str]:
    global COT_ENDPOINT
    image = os.environ.get("COT_IMAGE") or "ghcr.io/cot-intelligence/cot:latest"
    port = int(os.environ.get("COT_PORT") or _endpoint_port(COT_ENDPOINT))
    for _ in range(101):
        if not _port_in_use(port):
            break
        port += 1
    endpoint = _endpoint_for_port(port)
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    result = subprocess.run(
        [
            "docker", "run", "-d",
            "--name", container,
            "--restart", "unless-stopped",
            "--read-only",
            "--cap-drop", "ALL",
            "--security-opt", "no-new-privileges:true",
            "--tmpfs", "/tmp:rw,noexec,nosuid,nodev,size=16m",
            "--user", f"{os.getuid()}:{os.getgid()}",
            "-p", f"127.0.0.1:{port}:31337",
            "-v", f"{STATE_DIR}:/data",
            "-e", "COT_DB_PATH=/data/cot.db",
            image,
        ],
        capture_output=True,
        text=True,
    )
    output = (result.stdout or result.stderr).strip()
    if result.returncode != 0:
        return False, output or f"Could not start cot collector from {image}."
    COT_ENDPOINT = endpoint
    _write_endpoint_config(endpoint)
    if _wait_for_health(endpoint):
        return True, f"Started cot collector: {container} at {endpoint}"
    return False, f"Started cot collector, but health check failed at {endpoint}."


def _cmd_up(args: list[str]) -> int:
    if args:
        print("Usage: cot up", file=sys.stderr)
        return 1
    container = _container_name()
    ok, message = _docker_start_collectors(container)
    if ok:
        print(f"cot: {message}")
        print(f"cot: dashboard {COT_ENDPOINT}")
        return 0
    if message:
        print(f"cot: {message}", file=sys.stderr)
        return 1
    ok, message = _docker_run_collector(container)
    print(f"cot: {message}" if ok else f"cot: {message}", file=sys.stderr if not ok else sys.stdout)
    return 0 if ok else 1


def _cmd_down(args: list[str]) -> int:
    if args:
        print("Usage: cot down", file=sys.stderr)
        return 1
    container = _container_name()
    ok, message = _docker_stop_collectors(container)
    print(f"cot: {message}" if ok else f"cot: {message}", file=sys.stderr if not ok else sys.stdout)
    if ok:
        print(f"cot: local data and hooks are kept in {STATE_DIR}")
        return 0
    return 1


def _cmd_uninstall_hooks(agents: list[str]) -> tuple[list[dict], bool]:
    results: list[dict] = []
    for agent in agents:
        result = _uninstall_agent(agent)
        results.append(result)
        if result.get("status") == "ok":
            if result.get("changed"):
                print(f"cot: removed {agent} hooks -> {result['config_path']}")
                if result.get("backup_created"):
                    print(f"cot: backup saved -> {result['backup_created']['backup_path']}")
            else:
                print(f"cot: no {agent} hooks to remove")
        else:
            print(f"cot: failed to remove {agent} hooks: {result.get('error')}", file=sys.stderr)
    ok = all(r.get("status") == "ok" for r in results)
    return results, ok


def _confirm_purge(assume_yes: bool) -> bool:
    if assume_yes:
        return True
    if not sys.stdin.isatty():
        print("cot: purge deletes ~/.cot and requires --yes when not interactive.", file=sys.stderr)
        return False
    print("cot purge will remove:")
    print(f"  - Docker collector container: {_container_name()}")
    print("  - cot hooks from Claude, Cursor, and Codex")
    print(f"  - local cot state, bridge, and trace DB: {STATE_DIR}")
    answer = input("Type 'purge' to continue: ").strip()
    return answer == "purge"


def _cmd_purge(args: list[str]) -> int:
    assume_yes = False
    if args:
        if len(args) == 1 and args[0] in ("-y", "--yes"):
            assume_yes = True
        else:
            print("Usage: cot purge [--yes]", file=sys.stderr)
            return 1
    if not _confirm_purge(assume_yes):
        print("cot: purge cancelled")
        return 1

    container = _container_name()
    down_ok, down_message = _docker_rm_collector(container)
    print(f"cot: {down_message}" if down_ok else f"cot: {down_message}", file=sys.stderr if not down_ok else sys.stdout)

    _, hooks_ok = _cmd_uninstall_hooks(list(AGENTS))

    state_ok = True
    if STATE_DIR.exists():
        try:
            shutil.rmtree(STATE_DIR)
            print(f"cot: removed {STATE_DIR}")
        except OSError as exc:
            state_ok = False
            print(f"cot: failed to remove {STATE_DIR}: {exc}", file=sys.stderr)
    else:
        print(f"cot: no local state directory at {STATE_DIR}")

    if down_ok and hooks_ok and state_ok:
        print("cot: purge complete")
        return 0
    return 1


def _api_json(method: str, path: str, payload: dict | None = None) -> dict:
    data = None if payload is None else json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        f"{COT_ENDPOINT}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
        method=method,
    )
    with urllib.request.urlopen(req, timeout=5) as resp:
        return json.loads(resp.read().decode("utf-8"))


def _print_json(data: dict) -> None:
    print(json.dumps(data, indent=2, ensure_ascii=False, default=str))


def _cmd_retention(args: list[str]) -> int:
    action = args[0] if args else "status"
    try:
        if action == "status":
            _print_json(_api_json("GET", "/v1/retention"))
            return 0
        if action == "enable":
            days = int(args[1]) if len(args) > 1 else 30
            _print_json(_api_json("PUT", "/v1/retention", {"enabled": True, "days": days}))
            return 0
        if action == "disable":
            _print_json(_api_json("PUT", "/v1/retention", {"enabled": False}))
            return 0
        if action == "dry-run":
            _print_json(_api_json("POST", "/v1/retention/cleanup", {"dry_run": True}))
            return 0
        if action == "cleanup":
            _print_json(_api_json("POST", "/v1/retention/cleanup", {"dry_run": False}))
            return 0
    except (urllib.error.URLError, TimeoutError, OSError, ValueError) as exc:
        print(f"cot: retention command failed: {exc}", file=sys.stderr)
        return 1
    print("Usage: cot retention [status|enable [days]|disable|dry-run|cleanup]", file=sys.stderr)
    return 1


def _cmd_audit(args: list[str]) -> int:
    try:
        limit = int(args[0]) if args else 20
        _print_json(_api_json("GET", f"/v1/audit/self?limit={max(1, min(limit, 500))}"))
        return 0
    except (urllib.error.URLError, TimeoutError, OSError, ValueError) as exc:
        print(f"cot: audit command failed: {exc}", file=sys.stderr)
        return 1


