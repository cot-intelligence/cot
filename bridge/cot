def _resolve_endpoint() -> str:
    """COT_ENDPOINT env wins; otherwise the endpoint persisted at install time
    (config.json), so hooks reach the right collector even when the agent runs
    them with a bare environment."""
    env = os.environ.get("COT_ENDPOINT")
    if env:
        return env
    try:
        data = json.loads(CONFIG_PATH.read_text())
        ep = data.get("endpoint")
        if isinstance(ep, str) and ep:
            return ep.rstrip("/")
    except (json.JSONDecodeError, OSError):
        pass
    return DEFAULT_ENDPOINT


COT_ENDPOINT = _resolve_endpoint()

