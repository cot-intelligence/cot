STATE_DIR = Path.home() / ".cot"
CONFIG_PATH = STATE_DIR / "config.json"
TRANSCRIPT_OFFSETS = STATE_DIR / "transcript_offsets.json"
BRIDGE_PATH = STATE_DIR / "bin" / "cot"
HOOK_STATUS_PATH = STATE_DIR / "hooks_status.json"
