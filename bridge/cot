def _reindex_if_parser_changed() -> bool:
    """If the import parser changed since the last run, wipe import-origin data
    and offsets so the next import re-derives everything with the new logic.
    Returns True when a reset happened. Live hook data is left untouched by the
    server-side reset."""
    if _read_import_parser_version() == IMPORT_PARSER_VERSION:
        return False
    try:
        _api_json("POST", "/v1/import/reset", {})
    except (urllib.error.URLError, TimeoutError, OSError, ValueError):
        return False
    try:
        if IMPORT_OFFSETS_PATH.exists():
            IMPORT_OFFSETS_PATH.unlink()
    except OSError:
        pass
    print("cot: import parser updated — re-importing transcripts from scratch")
    return True


def _open_rb_nofollow(path: Path):
    """Open *path* read-only in binary, refusing to follow a symlink at the
    final component (closes the discovery→read TOCTOU window). Returns a file
    object or None on any error (including the path being a symlink)."""
    try:
        fd = os.open(str(path), os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0))
    except OSError:
        return None
    try:
        return os.fdopen(fd, "rb")
    except OSError:
        os.close(fd)
        return None


def _read_text_capped(path: Path) -> str | None:
    """Whole-file UTF-8 read with a size cap and symlink protection."""
    try:
        if path.stat().st_size > _MAX_TRANSCRIPT_BYTES:
            return None
    except OSError:
        return None
    fh = _open_rb_nofollow(path)
    if fh is None:
        return None
    try:
        return fh.read().decode("utf-8", errors="replace")
    except OSError:
        return None
    finally:
        fh.close()


def _import_read_new_lines(path: Path, offsets: dict[str, int]) -> tuple[list[str], int]:
    """Read new complete lines from *path* past the stored offset.

    Returns (lines, new_offset). Incomplete trailing lines (writer mid-flush)
    are not consumed — the offset stops at the last newline. Reads in binary so
    the stored byte offset seeks exactly; opens with O_NOFOLLOW and enforces a
    size cap.
    """
    key = str(path)
    start = offsets.get(key, 0)
    try:
        size = path.stat().st_size
    except OSError:
        return [], start
    if size > _MAX_TRANSCRIPT_BYTES:
        # Don't advance the offset; an oversized file is skipped, not consumed.
        return [], start
    if size < start:
        start = 0
    if size == start:
        return [], start
    fh = _open_rb_nofollow(path)
    if fh is None:
        return [], start
    try:
        fh.seek(start)
        chunk = fh.read().decode("utf-8", errors="replace")
    except OSError:
        return [], start
    finally:
        fh.close()
    # Only consume up to the last newline so partial writes are retried.
    last_nl = chunk.rfind("\n")
    if last_nl < 0:
        return [], start
    consumed = chunk[: last_nl + 1]
    new_offset = start + len(consumed.encode("utf-8"))
    lines = [ln for ln in consumed.splitlines() if ln.strip()]
    return lines, new_offset


def _safe_transcript_root(root: Path) -> Path | None:
    try:
        resolved = root.resolve(strict=True)
        home = Path.home().resolve(strict=True)
        resolved.relative_to(home)
        return resolved
    except (OSError, ValueError):
        return None


def _claude_transcript_root() -> Path:
    env = os.environ.get("COT_CLAUDE_HOME")
    return Path(env) if env else Path.home() / ".claude"


def _cursor_transcript_root() -> Path:
    env = os.environ.get("COT_CURSOR_HOME")
    return Path(env) if env else Path.home() / ".cursor"


def _codex_transcript_root() -> Path:
    env = os.environ.get("COT_CODEX_HOME")
    return Path(env) if env else Path.home() / ".codex"


def _discover_transcripts(agent: str) -> list[Path]:
    if agent == "claude":
        root = _safe_transcript_root(_claude_transcript_root())
        if not root:
            return []
        return sorted(root.glob("projects/**/*.jsonl"))
    if agent == "cursor":
        root = _safe_transcript_root(_cursor_transcript_root())
        if not root:
            return []
        return sorted(root.glob("projects/**/agent-transcripts/**/*.jsonl"))
    if agent == "codex":
        root = _safe_transcript_root(_codex_transcript_root())
        if not root:
            return []
        return sorted(root.glob("sessions/**/*.jsonl"))
    return []


def _claude_line_to_events(
    obj: dict,
    session_id: str,
    *,
    lineno: int = 0,
    mtime: float | None = None,
    state: dict | None = None,
    path: str = "",
) -> list[dict]:
    """Map a single Claude transcript JSONL line to hook-shaped payloads.

    ``state`` carries tool_use id -> (name, input) across lines so the
    ``tool_result`` blocks — which Claude writes in the *following* user
    message, not alongside the call — can be paired back to their tool name and
    emitted as PostToolUse events (with the result body and error status).
    """
    state = state if state is not None else {}
    events: list[dict] = []
    message = obj.get("message") if isinstance(obj.get("message"), dict) else {}
    role = obj.get("role") or message.get("role") or obj.get("type")
    content = obj.get("content")
    if content is None:
        content = message.get("content")
    ts = obj.get("timestamp")
    uuid = obj.get("uuid") or ""
    sid = obj.get("sessionId") or session_id
    cwd = obj.get("cwd")
    model = message.get("model") or obj.get("model")
    usage = message.get("usage") if isinstance(message.get("usage"), dict) else None
    base = {
        "session_id": sid,
        "cwd": cwd,
        "_import": True,
        "timestamp": ts,
    }

    if role == "user":
        # Tool results ride in user messages; pair them to the earlier call.
        if isinstance(content, list):
            for i, block in enumerate(content):
                if not isinstance(block, dict) or block.get("type") != "tool_result":
                    continue
                tool_use_id = block.get("tool_use_id") or ""
                result_content = block.get("content")
                if isinstance(result_content, str):
                    result_text = result_content
                elif isinstance(result_content, list):
                    result_text = _text_from_blocks(result_content)
                else:
                    result_text = ""
                tool_name, matched_input = state.get(tool_use_id, ("", {}))
                is_error = block.get("is_error", False)
                hook_name = "PostToolUseFailure" if is_error else "PostToolUse"
                events.append({
                    **base,
                    "hook_event_name": hook_name,
                    "tool_name": tool_name,
                    "tool_input": matched_input,
                    "tool_response": result_text,
                    "model": model,
                    "_dedup_key": f"{uuid}:post:{tool_use_id or i}" if uuid else None,
                })
        text = _text_from_blocks(content, clean_user=True) if isinstance(content, list) else _clean_user_text(str(content or ""))
        if text and not _is_interruption(text):
            events.append({
                **base,
                "hook_event_name": "UserPromptSubmit",
                "prompt": text,
                "_dedup_key": f"{uuid}:prompt" if uuid else None,
            })
        if isinstance(content, list):
            atts = _message_attachments(content)
            if atts and text:
                events.append({
                    **base,
                    "_attach_to_prompt": True,
                    "text": text,
                    "attachments": atts,
                })
    elif role == "assistant":
        if isinstance(content, list):
            usage_placed = False
            for i, block in enumerate(content):
                if not isinstance(block, dict):
                    continue
                btype = block.get("type")
                block_usage = None
                if usage and not usage_placed:
                    block_usage = usage
                    usage_placed = True
                if btype == "thinking":
                    think = block.get("thinking")
                    if think:
                        events.append({
                            **base,
                            "hook_event_name": "afterAgentThought",
                            "_synthetic_category": "thought",
                            "thought": str(think),
                            "model": model,
                            "usage": block_usage,
                            "_dedup_key": f"{uuid}:think:{i}" if uuid else None,
                        })
                elif btype == "text":
                    text = block.get("text")
                    if text:
                        events.append({
                            **base,
                            "hook_event_name": "afterAgentResponse",
                            "_synthetic_category": "response",
                            "response": str(text),
                            "model": model,
                            "usage": block_usage,
                            "_dedup_key": f"{uuid}:resp:{i}" if uuid else None,
                        })
                elif btype == "tool_use":
                    tool_name = block.get("name") or ""
                    tool_input = block.get("input") if isinstance(block.get("input"), dict) else {}
                    tool_id = block.get("id") or ""
                    if tool_id:
                        state[tool_id] = (tool_name, tool_input)
                    events.append({
                        **base,
                        "hook_event_name": "PreToolUse",
                        "tool_name": tool_name,
                        "tool_input": tool_input,
                        "model": model,
                        "usage": block_usage,
                        "_dedup_key": f"{uuid}:pre:{tool_id or i}" if uuid else None,
                    })
        else:
            text = str(content or "").strip()
            if text:
                events.append({
                    **base,
                    "hook_event_name": "afterAgentResponse",
                    "_synthetic_category": "response",
                    "response": text,
                    "model": model,
                    "usage": usage,
                    "_dedup_key": f"{uuid}:resp" if uuid else None,
                })

    return events


def _cursor_import_ts(mtime: float | None, lineno: int, block_idx: int = 0) -> str | None:
    """Cursor transcripts carry no per-event timestamps, so anchor on the file's
    mtime and offset by line/block position. This keeps events chronologically
    ordered within a session and roughly placed on the right day, instead of
    collapsing the whole history onto import time."""
    if mtime is None:
        return _now_z()
    dt = datetime.fromtimestamp(mtime, tz=timezone.utc) + timedelta(
        milliseconds=lineno * 100 + block_idx
    )
    # Fixed-precision so lexical string ordering (used by the DB's MIN/MAX(ts))
    # matches chronological ordering — without timespec a zero offset would drop
    # the fractional seconds and sort after the offset events.
    return dt.isoformat(timespec="milliseconds").replace("+00:00", "Z")


def _cursor_line_to_events(
    obj: dict,
    session_id: str,
    *,
    lineno: int = 0,
    mtime: float | None = None,
    state: dict | None = None,
    path: str = "",
) -> list[dict]:
    """Map a Cursor transcript line to hook-shaped payloads.

    Cursor transcripts differ from Claude's: no per-line timestamp or uuid, and
    no ``tool_result`` blocks (only the assistant's ``tool_use`` inputs). So we
    emit each tool call as a single standalone PostToolUse event (the end phase
    renders as an instant timeline item and counts in shell/web history) rather
    than a Pre/Post span that would otherwise dangle as "ongoing". Dedup keys
    are derived from the stable (path, line, block) position.
    """
    events: list[dict] = []
    message = obj.get("message") if isinstance(obj.get("message"), dict) else {}
    role = obj.get("role") or message.get("role") or obj.get("type")
    content = obj.get("content")
    if content is None:
        content = message.get("content")

    def _base(block_idx: int = 0) -> dict:
        return {
            "session_id": session_id,
            "_import": True,
            "timestamp": _cursor_import_ts(mtime, lineno, block_idx),
        }

    if role == "user":
        text = _text_from_blocks(content, clean_user=True) if isinstance(content, list) else _clean_user_text(str(content or ""))
        if text and not _is_interruption(text):
            events.append({
                **_base(),
                "hook_event_name": "UserPromptSubmit",
                "prompt": text,
                "_dedup_key": f"{path}:{lineno}:prompt",
            })
        if isinstance(content, list):
            atts = _message_attachments(content)
            if atts and text:
                events.append({
                    **_base(),
                    "_attach_to_prompt": True,
                    "text": text,
                    "attachments": atts,
                })
        return events

    if role == "assistant" and isinstance(content, list):
        for i, block in enumerate(content):
            if not isinstance(block, dict):
                continue
            btype = block.get("type")
            if btype == "text":
                text = block.get("text")
                if text:
                    events.append({
                        **_base(i),
                        "hook_event_name": "afterAgentResponse",
                        "_synthetic_category": "response",
                        "response": str(text),
                        "_dedup_key": f"{path}:{lineno}:resp:{i}",
                    })
            elif btype == "thinking":
                think = block.get("thinking")
                if think:
                    events.append({
                        **_base(i),
                        "hook_event_name": "afterAgentThought",
                        "_synthetic_category": "thought",
                        "thought": str(think),
                        "_dedup_key": f"{path}:{lineno}:think:{i}",
                    })
            elif btype == "tool_use":
                name = block.get("name") or ""
                inp = block.get("input")
                # ApplyPatch sends a raw patch string; keep dict or str as-is so
                # normalize can pull the target path out of either shape.
                tool_input = inp if isinstance(inp, (dict, str)) else {}
                events.append({
                    **_base(i),
                    "hook_event_name": "PostToolUse",
                    "tool_name": name,
                    "tool_input": tool_input,
                    "_dedup_key": f"{path}:{lineno}:tool:{i}",
                })
        return events

    return events


def _codex_tool_args(raw_args: object) -> dict:
    """Codex ``function_call`` arguments arrive as a JSON string."""
    if isinstance(raw_args, dict):
        return raw_args
    if isinstance(raw_args, str) and raw_args.strip():
        try:
            parsed = json.loads(raw_args)
            return parsed if isinstance(parsed, dict) else {}
        except json.JSONDecodeError:
            return {}
    return {}


def _codex_map_tool(name: str, raw_args: object) -> tuple[str, object]:
    """Map a Codex tool name + raw args onto a canonical (tool_name, tool_input)
    that normalize.categorize understands (shell/file_edit/etc.)."""
    args = _codex_tool_args(raw_args)
    if name in ("exec_command", "shell", "local_shell"):
        cmd = args.get("cmd") or args.get("command") or ""
        if isinstance(cmd, list):
            cmd = " ".join(str(c) for c in cmd)
        return "Bash", {"command": cmd}
    if name == "apply_patch":
        patch = args.get("input") or args.get("patch") or args.get("command") or ""
        if not patch and isinstance(raw_args, str):
            patch = raw_args
        return "apply_patch", {"command": patch}
    return name, args if args else {}


def _codex_reasoning_text(payload: dict) -> str:
    """Pull human-readable reasoning out of a Codex ``reasoning`` item. Most are
    encrypted (``encrypted_content``) or empty; only return real text."""
    parts: list[str] = []
    summary = payload.get("summary")
    if isinstance(summary, list):
        for s in summary:
            if isinstance(s, dict) and s.get("text"):
                parts.append(str(s["text"]))
            elif isinstance(s, str) and s.strip():
                parts.append(s)
    content = payload.get("content")
    if isinstance(content, str) and content.strip() and content != "None":
        parts.append(content)
    elif isinstance(content, list):
        t = _text_from_blocks(content)
        if t:
            parts.append(t)
    return "\n".join(parts).strip()


def _codex_line_to_events(
    obj: dict,
    session_id: str,
    *,
    lineno: int = 0,
    mtime: float | None = None,
    state: dict | None = None,
    path: str = "",
) -> list[dict]:
    """Map a Codex rollout JSONL line to hook-shaped payloads.

    Beyond messages and web searches, Codex records tool activity as
    ``function_call`` / ``custom_tool_call`` items with their results in
    separate ``*_output`` items keyed by ``call_id``. ``state`` correlates them
    so a call and its output become a Pre/Post span with the result body.
    """
    state = state if state is not None else {}
    events: list[dict] = []
    ts = obj.get("timestamp")
    kind = obj.get("type")
    payload = obj.get("payload") if isinstance(obj.get("payload"), dict) else {}
    base = {"session_id": session_id, "_import": True, "timestamp": ts}
    line_id = obj.get("id") or ""

    if kind != "response_item":
        return events

    pt = payload.get("type")
    if pt == "message" and payload.get("role") == "assistant":
        text_val = _text_from_blocks(payload.get("content"))
        if not text_val:
            return events
        model = payload.get("model") or obj.get("model")
        phase = payload.get("phase") or ""
        if phase == "final_answer":
            events.append({
                **base,
                "hook_event_name": "afterAgentResponse",
                "_synthetic_category": "response",
                "response": text_val,
                "model": model,
                "_dedup_key": f"{line_id}:resp" if line_id else None,
            })
        else:
            events.append({
                **base,
                "hook_event_name": "afterAgentThought",
                "_synthetic_category": "thought",
                "thought": text_val,
                "model": model,
                "_dedup_key": f"{line_id}:think" if line_id else None,
            })
    elif pt == "message" and payload.get("role") == "user":
        content = payload.get("content")
        text_val = _text_from_blocks(content, clean_user=True) if isinstance(content, list) else _clean_user_text(str(content or ""))
        if text_val and not _is_interruption(text_val):
            events.append({
                **base,
                "hook_event_name": "UserPromptSubmit",
                "prompt": text_val,
                "_dedup_key": f"{line_id}:prompt" if line_id else None,
            })
        if isinstance(content, list):
            atts = _message_attachments(content)
            if atts and text_val:
                events.append({
                    **base,
                    "_attach_to_prompt": True,
                    "text": text_val,
                    "attachments": atts,
                })
    elif pt == "reasoning":
        text_val = _codex_reasoning_text(payload)
        if text_val:
            events.append({
                **base,
                "hook_event_name": "afterAgentThought",
                "_synthetic_category": "thought",
                "thought": text_val,
                "_dedup_key": f"{line_id}:reason" if line_id else None,
            })
    elif pt == "web_search_call":
        action = payload.get("action") if isinstance(payload.get("action"), dict) else {}
        query = action.get("query") or payload.get("query") or ""
        if query:
            events.append({
                **base,
                "hook_event_name": "PostToolUse",
                "tool_name": "WebSearch",
                "tool_input": {"query": str(query)},
                "tool_response": {"status": payload.get("status"), "action": action},
                "_dedup_key": f"{line_id}:web" if line_id else None,
            })
    elif pt in ("function_call", "custom_tool_call"):
        name = payload.get("name") or ""
        call_id = payload.get("call_id") or ""
        raw_args = payload.get("arguments") if pt == "function_call" else payload.get("input")
        tool_name, tool_input = _codex_map_tool(name, raw_args)
        if call_id:
            state[call_id] = (tool_name, tool_input)
        dk = f"{call_id}:pre" if call_id else (f"{line_id}:pre" if line_id else None)
        events.append({
            **base,
            "hook_event_name": "PreToolUse",
            "tool_name": tool_name,
            "tool_input": tool_input,
            "_dedup_key": dk,
        })
    elif pt in ("function_call_output", "custom_tool_call_output"):
        call_id = payload.get("call_id") or ""
        output = payload.get("output")
        out_text = output if isinstance(output, str) else json.dumps(output, ensure_ascii=False, default=str)
        tool_name, tool_input = state.get(call_id, ("", {}))
        status = payload.get("status")
        is_error = status not in (None, "completed", "success")
        hook_name = "PostToolUseFailure" if is_error else "PostToolUse"
        dk = f"{call_id}:post" if call_id else (f"{line_id}:post" if line_id else None)
        events.append({
            **base,
            "hook_event_name": hook_name,
            "tool_name": tool_name,
            "tool_input": tool_input,
            "tool_response": out_text,
            "_dedup_key": dk,
        })

    return events


def _session_id_from_claude_path(path: Path) -> str | None:
    """Claude transcripts often have the session id in the first few lines."""
    try:
        with path.open("r", encoding="utf-8", errors="replace") as fh:
            for i, line in enumerate(fh):
                if i > 5:
                    break
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue
                sid = obj.get("sessionId") or obj.get("session_id")
                if sid:
                    return str(sid)
    except OSError:
        pass
    return path.stem


def _session_id_from_codex_path(path: Path) -> str:
    """Codex rollout filenames are rollout-<timestamp>-<uuid>.jsonl."""
    import re
    m = re.search(r"([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})", path.stem)
    if m:
        return m.group(1)
    return path.stem


def _fetch_session_origins() -> dict[str, str]:
    try:
        req = urllib.request.Request(
            f"{COT_ENDPOINT}/v1/sessions/origins",
            headers={"Content-Type": "application/json"},
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read().decode("utf-8"))
        return data.get("origins") or {}
    except (urllib.error.URLError, TimeoutError, OSError, json.JSONDecodeError):
        return {}


def _import_agent(agent: str, since: str | None, offsets: dict[str, int],
                  origins: dict[str, str], *, verbose: bool = True) -> int:
    """Import transcripts for one agent. Returns count of events posted."""
    transcripts = _discover_transcripts(agent)
    if verbose and not transcripts:
        print(f"cot import: no {agent} transcripts found", file=sys.stderr)
        return 0

    line_parser = {
        "claude": _claude_line_to_events,
        "cursor": _cursor_line_to_events,
        "codex": _codex_line_to_events,
    }[agent]

    source = agent
    posted = 0
    for path in transcripts:
        # Derive session id
        if agent == "claude":
            sid = _session_id_from_claude_path(path)
        elif agent == "codex":
            sid = _session_id_from_codex_path(path)
        else:
            sid = _session_id_from_claude_path(path) or path.stem

        if not sid:
            continue

        # v1: skip sessions that already have hook events
        if origins.get(sid) == "hook":
            continue

        # Apply --since filter on file mtime as a cheap pre-filter
        if since:
            try:
                mtime = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
                cutoff = datetime.fromisoformat(since.replace("Z", "+00:00"))
                if cutoff.tzinfo is None:
                    cutoff = cutoff.replace(tzinfo=timezone.utc)
                if mtime < cutoff:
                    continue
            except (OSError, ValueError):
                pass

        lines, new_offset = _import_read_new_lines(path, offsets)
        if not lines:
            offsets[str(path)] = new_offset
            continue

        if verbose:
            print(f"cot import: {agent} {path.name} ({len(lines)} new lines)")

        try:
            mtime = path.stat().st_mtime
        except OSError:
            mtime = None
        # Per-file state lets parsers correlate across lines (Claude/Codex pair a
        # tool call with its result; reset per file so ids never bleed across).
        state: dict = {}
        path_str = str(path)
        for lineno, line in enumerate(lines):
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            events = line_parser(
                obj, sid, lineno=lineno, mtime=mtime, state=state, path=path_str
            )
            for ev in events:
                # Strip None dedup keys
                if ev.get("_dedup_key") is None:
                    ev.pop("_dedup_key", None)
                _post(f"{COT_ENDPOINT}/v1/ingest/{source}", ev)
                posted += 1

        offsets[str(path)] = new_offset

    return posted


def _cmd_import(args: list[str]) -> int:
    import argparse
    parser = argparse.ArgumentParser(prog="cot import",
                                     description="Import historical agent transcripts")
    parser.add_argument("--agent", action="append", choices=["claude", "cursor", "codex"],
                        help="Agent(s) to import (default: all)")
    parser.add_argument("--since", help="Only import transcripts modified after YYYY-MM-DD")
    parser.add_argument("--report", action="store_true",
                        help="Print an ingestion quality/coverage report when done")
    parsed = parser.parse_args(args)

    agents = parsed.agent or ["claude", "cursor", "codex"]
    _reindex_if_parser_changed()
    origins = _fetch_session_origins()
    offsets = _import_offsets_load()
    total = 0

    for agent in agents:
        count = _import_agent(agent, parsed.since, offsets, origins)
        total += count

    _import_offsets_save(offsets)
    _write_import_parser_version()

    # Mark import-only sessions as completed — transcripts don't carry
    # lifecycle end events, so without this they'd stay "active" forever.
    if total > 0:
        try:
            req = urllib.request.Request(
                f"{COT_ENDPOINT}/v1/sessions/complete-imported",
                method="POST",
                headers={"Content-Type": "application/json"},
                data=b"{}",
            )
            with urllib.request.urlopen(req, timeout=10) as resp:
                result = json.loads(resp.read().decode("utf-8"))
                closed = result.get("completed", 0)
                if closed:
                    print(f"cot import: marked {closed} imported sessions as completed")
        except (urllib.error.URLError, TimeoutError, OSError):
            pass

    recovered = _recover_questions()
    if recovered:
        print(f"cot import: recovered {recovered} question answer(s)")

    print(f"cot import: done — {total} events posted")
    if parsed.report:
        _print_import_report()
    return 0


def _print_import_report() -> None:
    """Fetch and print the ingestion quality / coverage report."""
    try:
        data = _api_json("GET", "/v1/import/report")
    except (urllib.error.URLError, TimeoutError, OSError, ValueError) as exc:
        print(f"cot import: report unavailable ({exc})", file=sys.stderr)
        return
    print("\ncot import: coverage by source")
    print(f"  {'source':8s} {'events':>8s} {'tools':>7s} {'other%':>7s} {'tokens%':>8s} {'model%':>7s}")
    for r in data.get("by_source", []):
        print(
            f"  {str(r.get('source')):8s} {r.get('events', 0):>8d}"
            f" {r.get('tool_events', 0):>7d} {r.get('other_pct', 0):>6.1f}%"
            f" {r.get('token_coverage_pct', 0):>7.1f}%"
            f" {(100.0 * (r.get('with_model', 0)) / r['events']) if r.get('events') else 0:>6.1f}%"
        )
    cats = data.get("by_category", [])
    if cats:
        top = ", ".join(f"{c['category']}={c['events']}" for c in cats[:8])
        print(f"  categories: {top}")


def _scan_questions_full(path: Path) -> list[dict]:
    """Pair each AskQuestion tool_use with the agent's next text block.

    Cursor doesn't persist the user's selection, so the follow-up prose is the
    only signal. Reads the whole file (not a delta) so recovery is independent
    of import offsets. Returns [{"input", "response_text"}]."""
    pending: list[dict] = []
    out: list[dict] = []
    content_text = _read_text_capped(path)
    if content_text is None:
        return out
    for line in content_text.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        message = obj.get("message") if isinstance(obj.get("message"), dict) else {}
        role = obj.get("role") or message.get("role") or obj.get("type")
        content = obj.get("content")
        if content is None:
            content = message.get("content")
        if not isinstance(content, list):
            continue
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "tool_use" and block.get("name") == "AskQuestion":
                inp = block.get("input") if isinstance(block.get("input"), dict) else {}
                if isinstance(inp.get("questions"), list):
                    pending.append(inp)
            # Only the agent's own follow-up reveals the choice; a following
            # *user* message (e.g. a pasted request) is not the answer.
            elif block.get("type") == "text" and pending and role == "assistant":
                response_text = str(block.get("text") or "")
                if not response_text.strip():
                    continue
                for inp in pending:
                    out.append({"input": inp, "response_text": response_text})
                pending = []
    return out


def _question_qids(tool_input: dict) -> list[str]:
    questions = tool_input.get("questions") if isinstance(tool_input.get("questions"), list) else []
    return [
        str(q.get("id") or q.get("prompt") or q.get("question") or "")
        for q in questions
        if isinstance(q, dict)
    ]


def _recover_questions() -> int:
    """Host-side AskQuestion answer recovery, pushed to the collector.

    Works for both live and imported Cursor sessions: the transcript filename
    stem is the session id used in storage. Posts only non-empty answers.
    Clears previously recovered (heuristic) answers first so a re-run replaces
    stale guesses rather than leaving them stuck."""
    try:
        _api_json("POST", "/v1/questions/reset-recovered", {})
    except (urllib.error.URLError, TimeoutError, OSError, ValueError):
        pass
    posted = 0
    for path in _discover_transcripts("cursor"):
        sid = path.stem
        for item in _scan_questions_full(path):
            inp = item["input"]
            resp = _cursor_question_response(inp, item["response_text"])
            if not resp.get("answers"):
                continue
            payload = {
                "session_id": sid,
                "title": inp.get("title"),
                "qids": _question_qids(inp),
                "response": resp,
            }
            try:
                req = urllib.request.Request(
                    f"{COT_ENDPOINT}/v1/questions/answer",
                    data=json.dumps(payload, ensure_ascii=False, default=str).encode("utf-8"),
                    headers={"Content-Type": "application/json"},
                    method="POST",
                )
                with urllib.request.urlopen(req, timeout=5) as r:
                    result = json.loads(r.read().decode("utf-8"))
                    posted += int(result.get("updated") or 0)
            except (urllib.error.URLError, TimeoutError, OSError, json.JSONDecodeError):
                pass
    return posted


def _cmd_recover_questions(args: list[str]) -> int:
    n = _recover_questions()
    print(f"cot recover-questions: filled {n} answer(s) from transcripts")
    return 0


def _cmd_reimport(args: list[str]) -> int:
    """Wipe previously imported data and re-ingest all transcripts fresh.

    Clears the collector's import-origin rows and the local byte offsets, then
    runs a full import so transcripts are re-parsed with the current logic.
    Live hook data is left untouched.
    """
    try:
        res = _api_json("POST", "/v1/import/reset", {})
        print(
            f"cot reimport: cleared {res.get('deleted_events', 0)} events,"
            f" {res.get('deleted_sessions', 0)} sessions"
        )
    except (urllib.error.URLError, TimeoutError, OSError, ValueError) as exc:
        print(f"cot reimport: reset failed: {exc}", file=sys.stderr)
        return 1

    try:
        if IMPORT_OFFSETS_PATH.exists():
            IMPORT_OFFSETS_PATH.unlink()
    except OSError as exc:
        print(f"cot reimport: could not clear offsets: {exc}", file=sys.stderr)

    agents = ["claude", "cursor", "codex"]
    origins = _fetch_session_origins()
    offsets: dict[str, int] = {}
    total = 0
    for agent in agents:
        total += _import_agent(agent, None, offsets, origins, verbose=True)
    _import_offsets_save(offsets)

    if total > 0:
        try:
            req = urllib.request.Request(
                f"{COT_ENDPOINT}/v1/sessions/complete-imported",
                method="POST",
                headers={"Content-Type": "application/json"},
                data=b"{}",
            )
            with urllib.request.urlopen(req, timeout=10) as resp:
                result = json.loads(resp.read().decode("utf-8"))
                closed = result.get("completed", 0)
                if closed:
                    print(f"cot reimport: marked {closed} imported sessions as completed")
        except (urllib.error.URLError, TimeoutError, OSError, json.JSONDecodeError):
            pass

    recovered = _recover_questions()
    if recovered:
        print(f"cot reimport: recovered {recovered} question answer(s)")

    _write_import_parser_version()
    print(f"cot reimport: done — {total} events posted")
    return 0


def _cmd_watch(args: list[str]) -> int:
    import argparse
    import time as _time

    parser = argparse.ArgumentParser(prog="cot watch",
                                     description="Watch for new transcript lines")
    parser.add_argument("--agent", action="append", choices=["claude", "cursor", "codex"],
                        help="Agent(s) to watch (default: all)")
    parser.add_argument("--interval", type=int, default=10,
                        help="Seconds between poll cycles (default: 10)")
    parsed = parser.parse_args(args)

    agents = parsed.agent or ["claude", "cursor", "codex"]
    interval = max(2, parsed.interval)

    print(f"cot watch: monitoring {', '.join(agents)} (poll every {interval}s)")
    print(f"cot watch: endpoint {COT_ENDPOINT}")

    # Initial import pass
    _reindex_if_parser_changed()
    origins = _fetch_session_origins()
    offsets = _import_offsets_load()
    for agent in agents:
        count = _import_agent(agent, None, offsets, origins)
        if count:
            print(f"cot watch: initial import — {count} {agent} events")
    _import_offsets_save(offsets)
    _write_import_parser_version()

    # Tail loop — refresh origins every 10 cycles so newly-hooked sessions
    # are skipped promptly (avoids duplicating hook data from transcripts).
    cycle = 0
    try:
        while True:
            _time.sleep(interval)
            cycle += 1
            if cycle % 10 == 0:
                origins = _fetch_session_origins()
            offsets = _import_offsets_load()
            for agent in agents:
                count = _import_agent(agent, None, offsets, origins, verbose=False)
                if count:
                    print(f"cot watch: +{count} {agent} events")
            _import_offsets_save(offsets)
    except KeyboardInterrupt:
        print("\ncot watch: stopped")
        return 0


def main() -> int:
    if len(sys.argv) >= 2 and sys.argv[1] == "install":
        return _cmd_install(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "status":
        return _cmd_status()
    if len(sys.argv) >= 2 and sys.argv[1] == "up":
        return _cmd_up(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "down":
        return _cmd_down(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "purge":
        return _cmd_purge(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "retention":
        return _cmd_retention(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "audit":
        return _cmd_audit(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "import":
        return _cmd_import(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "reimport":
        return _cmd_reimport(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "recover-questions":
        return _cmd_recover_questions(sys.argv[2:])
    if len(sys.argv) >= 2 and sys.argv[1] == "watch":
        return _cmd_watch(sys.argv[2:])
    if len(sys.argv) < 3 or sys.argv[1] != "hook":
        print(
            "Usage:\n"
            "  cot hook <claude|cursor|codex>   # reads a hook payload from stdin\n"
            "  cot install [claude cursor codex]  # wire up agent hook configs\n"
            "  cot import [--agent X] [--since]   # import historical transcripts\n"
            "  cot reimport                       # wipe + re-import all transcripts\n"
            "  cot recover-questions              # fill AskQuestion answers from transcripts\n"
            "  cot watch [--agent X] [--interval]  # tail transcripts continuously\n"
            "  cot status                         # show endpoint + installed hooks\n"
            "  cot up                             # start/resume collector container\n"
            "  cot down                           # stop collector container\n"
            "  cot purge [--yes]                  # remove container, hooks, and ~/.cot\n"
            "  cot retention [status|dry-run]     # manage local cleanup policy\n"
            "  cot audit [limit]                  # show cot self-audit events",
            file=sys.stderr,
        )
        return 1
    source = sys.argv[2]
    if source not in AGENTS:
        print(f"Unknown source: {source}", file=sys.stderr)
        return 1

    raw = sys.stdin.read()
    try:
        body = json.loads(raw) if raw.strip() else {}
    except json.JSONDecodeError:
        body = {"_raw": raw}

    hook = body.get("hook_event_name") or body.get("hook") or body.get("event") or ""
    redundant = source == "cursor" and hook in CURSOR_REDUNDANT_HOOKS
    # Cursor transcript-only artifacts are posted by _emit_cursor_artifacts. For
    # plan-mode turns it also posts the filled response, so skip the default
    # empty response in that case.
    handled = source == "cursor" and _emit_cursor_artifacts(body, source)
    if not redundant and not handled:
        _post(f"{COT_ENDPOINT}/v1/ingest/{source}", body)
    if source == "claude":
        _emit_claude_responses(body, source)
        if hook in ("SessionStart", "sessionStart"):
            _log_launch(body)
    elif source == "codex":
        _emit_codex_responses(body, source)

    response = _hook_response(source, body)
    if response is not None:
        print(json.dumps(response))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
