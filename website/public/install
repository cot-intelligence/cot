#!/bin/sh
set -e

# cot bootstrap installer — https://cot.run/install
#
#   curl -fsSL https://cot.run/install | sh
#
# Starts the cot collector in Docker on the first free port, installs the local
# bridge, and wires up hooks for every supported agent. Fully non-interactive —
# your traces stay on your machine, no accounts.
#
# Override anything via env before piping, e.g.
#   COT_PORT=9000 COT_AGENTS="claude cursor" curl -fsSL https://cot.run/install | sh

CONTAINER="${COT_CONTAINER:-cot}"
IMAGE="${COT_IMAGE:-ghcr.io/cot-intelligence/cot:latest}"
PORT="${COT_PORT:-8000}"
COT_ENDPOINT="${COT_ENDPOINT:-http://localhost:${PORT}}"
COT_HOME="${HOME}/.cot"
BIN_DIR="${COT_HOME}/bin"
TARGET="${BIN_DIR}/cot"

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_TTY=1
  C_RESET="$(printf '\033[0m')"
  C_BOLD="$(printf '\033[1m')"
  C_VERMILION="$(printf '\033[38;2;255;69;0m')"
  C_CLEAR="$(printf '\033[2K')"
else
  C_TTY=0
  C_RESET=""
  C_BOLD=""
  C_VERMILION=""
  C_CLEAR=""
fi

title() {
  printf '%s%s%s\n' "${C_VERMILION}${C_BOLD}" '    ' "${C_RESET}"
  printf '%s%s%s\n' "${C_VERMILION}${C_BOLD}" '┏┏┓╋' "${C_RESET}"
  printf '%s%s%s\n' "${C_VERMILION}${C_BOLD}" '┗┗┛┗' "${C_RESET}"
  printf '%s%s%s\n' "${C_VERMILION}${C_BOLD}" '    ' "${C_RESET}"
  printf '%s\n' "cot installer"
  printf '%s\n\n' "local traces | local dashboard | one command"
}

section() {
  printf '\n%s\n' "$1"
}

step() {
  printf '› %s\n' "$1"
}

ok() {
  printf '✓ %s\n' "$1"
}

warn() {
  printf '! %s\n' "$1"
}

fail() {
  printf 'x %s\n' "$1" >&2
}

details() {
  label="$1"
  body="$2"
  [ -n "${body}" ] || return 0
  printf '%s\n' "  ${label}" >&2
  printf '%s\n' "${body}" | while IFS= read -r line; do
    printf '    %s\n' "${line}" >&2
  done
}

ACTIVE_PID=""
ACTIVE_LOG=""
handle_interrupt() {
  trap - INT TERM
  [ "${C_TTY}" = "1" ] && printf '\r%s\r' "${C_CLEAR}" >&2
  if [ -n "${ACTIVE_PID}" ] && kill -0 "${ACTIVE_PID}" 2>/dev/null; then
    kill "${ACTIVE_PID}" 2>/dev/null || true
    wait "${ACTIVE_PID}" 2>/dev/null || true
  fi
  [ -n "${ACTIVE_LOG}" ] && rm -f "${ACTIVE_LOG}"
  printf '\n! Install interrupted by user.\n' >&2
  printf '%s\n' "  No further changes will be made by this run." >&2
  printf '%s\n' "  Re-run the installer when you are ready." >&2
  exit 130
}

trap handle_interrupt INT TERM

table_line() {
  printf '  %s\n' "+--------------+--------------------------------------------------------------+"
}

table_row() {
  printf '  | %-12s | %-60.60s |\n' "$1" "$2"
}

summary_table() {
  table_line
  table_row "Image" "${IMAGE}"
  table_row "Container" "${CONTAINER}"
  table_row "Endpoint" "${COT_ENDPOINT}"
  table_row "Bridge" "${TARGET}"
  table_row "Agents" "${COT_AGENTS:-all}"
  table_line
}

spinner_frame() {
  case "$1" in
    0) printf '-' ;;
    1) printf '\\' ;;
    2) printf '|' ;;
    *) printf '/' ;;
  esac
}

RUN_OUTPUT=""
RUN_COUNT=0
run_spinner() {
  label="$1"
  shift
  log="${TMPDIR:-/tmp}/cot-install.$$.$RUN_COUNT.log"
  RUN_COUNT=$((RUN_COUNT + 1))
  ACTIVE_LOG="${log}"
  [ "${C_TTY}" = "1" ] || step "${label}"
  set +e
  "$@" >"${log}" 2>&1 &
  pid=$!
  ACTIVE_PID="${pid}"
  i=0
  if [ "${C_TTY}" = "1" ]; then
    while kill -0 "${pid}" 2>/dev/null; do
      frame=$(spinner_frame "${i}")
      printf '\r%s %s' "${frame}" "${label}"
      i=$(( (i + 1) % 4 ))
      sleep 0.12
    done
  fi
  wait "${pid}"
  code=$?
  ACTIVE_PID=""
  set -e
  [ "${C_TTY}" = "1" ] && printf '\r%s\r' "${C_CLEAR}"
  RUN_OUTPUT=$(cat "${log}" 2>/dev/null)
  rm -f "${log}"
  ACTIVE_LOG=""
  return "${code}"
}

wait_for_health() {
  endpoint="$1"
  RUN_OUTPUT=""
  i=0
  set +e
  while :; do
    health_output=$(curl -fsS "${endpoint}/health" 2>&1 >/dev/null)
    code=$?
    if [ "${code}" -eq 0 ]; then
      set -e
      [ "${C_TTY}" = "1" ] && printf '\r%s\r' "${C_CLEAR}"
      return 0
    fi
    RUN_OUTPUT="${health_output}"
    i=$((i + 1))
    if [ "${i}" -gt 60 ]; then
      set -e
      [ "${C_TTY}" = "1" ] && printf '\r%s\r' "${C_CLEAR}"
      return 1
    fi
    if [ "${C_TTY}" = "1" ]; then
      frame=$(spinner_frame "$((i % 4))")
      printf '\r%s Waiting for collector at %s' "${frame}" "${endpoint}"
    fi
    sleep 1
  done
}

title
summary_table

# 1. Docker must be present and running.
section "System Check"
step "Checking Docker"
if ! command -v docker >/dev/null 2>&1; then
  echo "" >&2
  fail "Docker is required but not installed."
  printf '%s\n' "  Install Docker Desktop: https://docs.docker.com/get-docker/" >&2
  exit 1
fi
if ! run_spinner "Checking Docker daemon" docker info; then
  echo "" >&2
  fail "Docker is installed but not running."
  printf '%s\n' "  Start Docker and re-run this installer." >&2
  details "Error found" "${RUN_OUTPUT}"
  exit 1
fi
ok "Docker is ready"

# 2. Start (or reuse) the collector container on the first free host port.

collector_published_port() {
  mapped=$(docker port "${CONTAINER}" 8000/tcp 2>/dev/null | head -n1)
  case "${mapped}" in
    *:*) echo "${mapped##*:}"; return 0 ;;
  esac
  return 1
}

collector_healthy() {
  curl -fsS --max-time 2 "${1}/health" >/dev/null 2>&1
}

# True when the running container is not on the freshly-pulled image, so a
# "reinstall" actually delivers updates instead of silently keeping old code.
container_is_stale() {
  running=$(docker inspect -f '{{.Image}}' "${CONTAINER}" 2>/dev/null) || return 1
  latest=$(docker image inspect -f '{{.Id}}' "${IMAGE}" 2>/dev/null) || return 1
  [ -n "${running}" ] && [ -n "${latest}" ] && [ "${running}" != "${latest}" ]
}

# Pull the latest image up front (best effort — stay on the cached image when
# offline). docker run never re-pulls an existing :latest on its own, so without
# this an existing install can never upgrade.
section "Collector"
if run_spinner "Pulling collector image" docker pull "${IMAGE}"; then
  ok "Using ${IMAGE}"
else
  warn "Could not pull ${IMAGE}; using cached image if available"
  details "Warning found" "${RUN_OUTPUT}"
fi

# Best-effort check whether a TCP port is already listening. Falls back to
# "assume free" when no probe tool exists — the docker-run retry below is the
# real safety net.
port_in_use() {
  _p="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"${_p}" -sTCP:LISTEN >/dev/null 2>&1
  elif command -v nc >/dev/null 2>&1; then
    nc -z 127.0.0.1 "${_p}" >/dev/null 2>&1
  else
    return 1
  fi
}

reuse_ok=
if docker ps --format '{{.Names}}' | grep -qx "${CONTAINER}"; then
  if published=$(collector_published_port); then
    PORT="${published}"
    COT_ENDPOINT="http://localhost:${PORT}"
    if container_is_stale; then
      warn "A newer cot image is available; recreating collector"
    elif collector_healthy "${COT_ENDPOINT}"; then
      ok "Collector already running (container: ${CONTAINER}, port ${PORT})"
      reuse_ok=1
    else
      warn "Collector is running but not reachable on port ${PORT}; recreating"
    fi
  else
    warn "Collector is running without a published port; recreating"
  fi
  if [ -z "${reuse_ok}" ]; then
    docker rm -f "${CONTAINER}" >/dev/null 2>&1 || true
  fi
fi

if [ -z "${reuse_ok}" ]; then
  # Remove any stopped/half-created container so we can bind a fresh free port.
  if docker ps -a --format '{{.Names}}' | grep -qx "${CONTAINER}"; then
    docker rm -f "${CONTAINER}" >/dev/null 2>&1 || true
  fi

  # Skip ahead of any port already in use, then let docker confirm the bind.
  scan=0
  while port_in_use "${PORT}"; do
    scan=$((scan + 1)); [ "${scan}" -gt 100 ] && break
    PORT=$((PORT + 1))
  done

  attempt=0
  while :; do
    COT_ENDPOINT="http://localhost:${PORT}"
    if run_spinner "Starting collector on port ${PORT}" docker run -d \
      --name "${CONTAINER}" \
      --restart unless-stopped \
      -p "${PORT}:8000" \
      -v "${COT_HOME}:/root/.cot" \
      "${IMAGE}"; then
      break
    fi

    case "${RUN_OUTPUT}" in
      *"already allocated"*|*"address already in use"*|*"Bind for"*|*"port is already"*)
        docker rm -f "${CONTAINER}" >/dev/null 2>&1 || true
        attempt=$((attempt + 1))
        if [ "${attempt}" -gt 50 ]; then
          fail "Could not find a free port after 50 attempts (last tried ${PORT})."
          printf '%s\n' "  Re-run with COT_PORT=<free-port>." >&2
          exit 1
        fi
        warn "Port ${PORT} is busy; trying $((PORT + 1))"
        PORT=$((PORT + 1))
        ;;
      *)
        fail "Could not start cot collector."
        details "Error found" "${RUN_OUTPUT}"
        exit 1
        ;;
    esac
  done
  ok "Collector running on port ${PORT}"
fi

# 3. Wait for the collector to answer health checks.
if ! wait_for_health "${COT_ENDPOINT}"; then
  fail "Collector did not become healthy in time."
  printf '%s\n' "  Inspect logs with: docker logs ${CONTAINER}" >&2
  details "Error found" "${RUN_OUTPUT}"
  exit 1
fi
ok "Collector is healthy at ${COT_ENDPOINT}"

# 4. Install the local bridge from the running collector.
section "Bridge"
if ! run_spinner "Preparing ${BIN_DIR}" mkdir -p "${BIN_DIR}"; then
  fail "Could not create ${BIN_DIR}."
  details "Error found" "${RUN_OUTPUT}"
  exit 1
fi
if ! run_spinner "Downloading bridge" curl -fsSL "${COT_ENDPOINT}/cot" -o "${TARGET}"; then
  fail "Could not download cot bridge."
  details "Error found" "${RUN_OUTPUT}"
  exit 1
fi
if ! run_spinner "Making bridge executable" chmod +x "${TARGET}"; then
  fail "Could not make ${TARGET} executable."
  details "Error found" "${RUN_OUTPUT}"
  exit 1
fi
ok "Bridge installed to ${TARGET}"

# Persist the endpoint so hooks reach this collector regardless of the
# environment the agent runs them in.
if ! config_output=$({ printf '{"endpoint": "%s"}\n' "${COT_ENDPOINT}" > "${COT_HOME}/config.json"; } 2>&1); then
  fail "Could not write ${COT_HOME}/config.json."
  details "Error found" "${config_output}"
  exit 1
fi
ok "Endpoint saved to ${COT_HOME}/config.json"

# 5. Wire up agent hooks. Installs every supported agent by default; override
#    with COT_AGENTS (space-separated names, or "none" to skip). The bridge
#    merges into each agent's config idempotently and leaves the rest alone.
SELECTION="${COT_AGENTS:-all}"
AGENTS=""
case " ${SELECTION} " in
  *" none "*|*" None "*|*" NONE "*) AGENTS="" ;;
  *" all "*|*" All "*|*" ALL "*)    AGENTS="claude cursor codex" ;;
  *)
    for token in ${SELECTION}; do
      case "${token}" in
        claude|Claude|CLAUDE) AGENTS="${AGENTS} claude" ;;
        cursor|Cursor|CURSOR) AGENTS="${AGENTS} cursor" ;;
        codex|Codex|CODEX)    AGENTS="${AGENTS} codex" ;;
      esac
    done
    ;;
esac

if [ -n "${AGENTS}" ]; then
  section "Agent Hooks"
  if run_spinner "Wiring hooks for:${AGENTS}" env COT_ENDPOINT="${COT_ENDPOINT}" "${TARGET}" install ${AGENTS}; then
    [ -z "${RUN_OUTPUT}" ] || printf '%s\n' "${RUN_OUTPUT}"
  else
    fail "Could not wire agent hooks."
    details "Error found" "${RUN_OUTPUT}"
    exit 1
  fi
fi

# 7. Make `cot` available on the PATH for interactive use.
section "Shell Setup"
PATH_LINE="export PATH=\"\${HOME}/.cot/bin:\${PATH}\""
case "${SHELL##*/}" in
  zsh)  PROFILE="${HOME}/.zshrc" ;;
  bash) PROFILE="${HOME}/.bashrc" ;;
  *)    PROFILE="${HOME}/.profile" ;;
esac
if [ -f "${PROFILE}" ] && grep -qs ".cot/bin" "${PROFILE}"; then
  ok "~/.cot/bin is already on PATH in ${PROFILE}"
else
  if ! path_output=$({ printf '\n# cot bridge\n%s\n' "${PATH_LINE}" >> "${PROFILE}"; } 2>&1); then
    fail "Could not update ${PROFILE}."
    details "Error found" "${path_output}"
    exit 1
  fi
  echo ""
  ok "Added ~/.cot/bin to your PATH in ${PROFILE}"
  printf '%s\n' "  Open a new shell or run: ${PATH_LINE}"
fi

section "Complete"
ok "cot is live"
table_line
table_row "Dashboard" "${COT_ENDPOINT}"
table_row "Status" "${TARGET} status"
table_row "Stop" "docker stop ${CONTAINER}"
table_line
